local function mkCorner(p,r) local c=Instance.new("UICorner",p); c.CornerRadius=UDim.new(0,r or 8); return c end
local function mkStroke(p,col,thick) local s=Instance.new("UIStroke",p); s.Color=col or COLORS.accent; s.Thickness=thick or 1; return s end
local function mkPad(p,l,r,t,b) local pd=Instance.new("UIPadding",p); pd.PaddingLeft=UDim.new(0,l or 0); pd.PaddingRight=UDim.new(0,r or 0); pd.PaddingTop=UDim.new(0,t or 0); pd.PaddingBottom=UDim.new(0,b or 0) end
local function mkLabel(parent,text,size,color,font,xalign)
    local l=Instance.new("TextLabel",parent); l.BackgroundTransparency=1
    l.Size=size or UDim2.new(1,0,1,0); l.Text=text or ""; l.TextColor3=color or COLORS.textMain
    l.TextScaled=true; l.Font=font or Enum.Font.Gotham; l.TextXAlignment=xalign or Enum.TextXAlignment.Left
    return l
end

local function makeDraggable(elem, handle, onEnd)
    handle = handle or elem
    local dragging, dragInput, dragStart, startPos = false, nil, nil, nil
    addConn(handle.InputBegan:Connect(function(input)
        if (input.UserInputType==Enum.UserInputType.MouseButton1 or input.UserInputType==Enum.UserInputType.Touch) and not dragging then
            dragging=true; dragInput=input; dragStart=input.Position; startPos=elem.Position
        end
    end))
    addConn(UIS.InputChanged:Connect(function(input)
        if input==dragInput and dragging then
            local d=input.Position-dragStart
            elem.Position=UDim2.new(startPos.X.Scale,startPos.X.Offset+d.X,startPos.Y.Scale,startPos.Y.Offset+d.Y)
        end
    end))
    addConn(UIS.InputEnded:Connect(function(input)
        if input==dragInput then dragging=false; dragInput=nil; if onEnd then onEnd() end end
    end))
end

