local FILE_NAME="DemoPRO_Config.json"
local function saveSettings()
    local data={_toggles={}, _overlayPos=nil, _miniPos=nil}
    for label,tbl in pairs(getgenv().ToolStates or {}) do
        data._toggles[label]=tbl.state
    end
    data._overlayPos={
        sx=glassOverlay.Position.X.Scale, ox=glassOverlay.Position.X.Offset,
        sy=glassOverlay.Position.Y.Scale, oy=glassOverlay.Position.Y.Offset,
    }
    data._miniPos={
        sx=miniIcon.Position.X.Scale, ox=miniIcon.Position.X.Offset,
        sy=miniIcon.Position.Y.Scale, oy=miniIcon.Position.Y.Offset,
    }
    pcall(function()
        if writefile then writefile(FILE_NAME, HS:JSONEncode(data)) end
    end)
end
local function loadSettings()
    if not pcall(function() return isfile(FILE_NAME) end) then return {} end
    local ok2,res=pcall(function() return HS:JSONDecode(readfile(FILE_NAME)) end)
    return ok2 and res or {}
end

