local function predictGhost()
    local found,absent={},{}
    for k,v in pairs(evidenceCards) do
        if v.found then table.insert(found,k) end
        if v.absent then table.insert(absent,k) end
    end
    if #found==0 and #absent==0 then return "Đang quét..." end
    local matches={}
    for gName,evMap in pairs(GDB) do
        local ok2=true
        for _,ev in ipairs(found) do if not evMap[ev] then ok2=false; break end end
        if ok2 then for _,ev in ipairs(absent) do if evMap[ev] then ok2=false; break end end end
        if ok2 then table.insert(matches,gName) end
    end
    if #found>=3 and #matches==0 then return "⚠️ Skinwalker" end
    if #matches==0 then return "Không rõ" end
    local out=""
    for i=1,math.min(#matches,3) do out=out..matches[i]..(i<math.min(#matches,3) and ", " or "") end
    if #matches>3 then out=out.." +"..(#matches-3) end
    return out
end

