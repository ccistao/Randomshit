local function setEvidence(name,found,extra,absent)
    local ev=evidenceCards[name]; if not ev then return end
    if found and not ev.found then
        ev.found=true; ev.absent=false
        ev.dot.BackgroundColor3=COLORS.green; ev.nameLabel.TextColor3=COLORS.textMain
        ev.valLabel.TextColor3=COLORS.green; ev.valLabel.Text=extra or "Đã phát hiện ✓"
        ev.card.BackgroundColor3=Color3.fromRGB(18,32,22)
        if ev.stroke then ev.stroke.Color=COLORS.green end
    elseif absent and not ev.found and not ev.absent then
        ev.absent=true
        ev.dot.BackgroundColor3=COLORS.red; ev.valLabel.TextColor3=COLORS.red
        ev.valLabel.Text=extra or "Không có ✗"
        ev.card.BackgroundColor3=Color3.fromRGB(32,14,14)
        if ev.stroke then ev.stroke.Color=COLORS.red end
    elseif not found and not absent and extra and not ev.found then
        ev.valLabel.Text=extra
    end
end

