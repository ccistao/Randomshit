    end

    if AUTO_UPGRADE then
        statusLbl.Text = "All MAX! Auto off"
        AUTO_UPGRADE = false
        autoBtn.Text = "AUTO: OFF"
        autoBtn.BackgroundColor3 = Color3.fromRGB(150,50,50)
    end
end

