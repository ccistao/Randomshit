task.spawn(function()
    local wasLow2 = false
    local repairCount = 0
    local lastFire = 0
    while panel.Parent do
        task.wait(0.1)
        local hp = getDoorHp()
        if hp then
            local pct = math.floor(hp * 100)
            doorHpLbl.Text = "Door: " .. pct .. "%"
            doorHpLbl.TextColor3 = hp > HP_THRESHOLD and Color3.fromRGB(134,239,172) or Color3.fromRGB(239,68,68)
            if hp >= HP_RESET and wasLow2 then
                wasLow2 = false
                repairCount = 0
            end
            if AUTO_REPAIR and hp <= HP_THRESHOLD then
                wasLow2 = true
                local now = tick()
                local cooldownOk = (now - lastFire) >= 0.8
                if repairCount >= MAX_REPAIRS and isRepairReady() and cooldownOk then
                    repairCount = 0
                end
                if repairCount < MAX_REPAIRS and isRepairReady() and cooldownOk then
                    local remote = RepairRemote or Remotes:FindFirstChild("Base")
                    if remote then
                        remote:FireServer("repair")
                        lastFire = now
                        repairCount += 1
                        statusLbl.Text = "Repaired! HP:" .. pct .. "% (" .. repairCount .. "/" .. MAX_REPAIRS .. ")"
                    end
                end
            end
        else
            doorHpLbl.Text = "Door: ---"
        end
    end
end)

