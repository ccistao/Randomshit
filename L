local player = game.Players.LocalPlayer
local userInputService = game:GetService("UserInputService")
local tweenService = game:GetService("TweenService")

local toggled = false
local customKey = nil

local screenGui = Instance.new("ScreenGui")
screenGui.Name = "Draggable_Toggle_UI"
screenGui.ResetOnSpawn = false
screenGui.Parent = player:WaitForChild("PlayerGui")

local button = Instance.new("TextButton")
button.Size = UDim2.new(0, 120, 0, 54)
button.Position = UDim2.new(0.5, -60, 0.2, 0)
button.BackgroundColor3 = Color3.fromRGB(35, 35, 35)
button.Text = "STATE: OFF"
button.TextColor3 = Color3.fromRGB(255, 255, 255)
button.Font = Enum.Font.GothamBold
button.TextSize = 16
button.AutoButtonColor = false
button.Parent = screenGui
Instance.new("UICorner", button).CornerRadius = UDim.new(0, 14)

local stroke = Instance.new("UIStroke")
stroke.Color = Color3.fromRGB(0, 170, 255)
stroke.Thickness = 1.5
stroke.Transparency = 0.7
stroke.Parent = button

local keyFrame = Instance.new("Frame")
keyFrame.Size = UDim2.new(0, 120, 0, 32)
keyFrame.Position = UDim2.new(0, button.Position.X.Offset, 0, button.Position.Y.Offset + 62)
keyFrame.BackgroundColor3 = Color3.fromRGB(25, 25, 25)
keyFrame.BorderSizePixel = 0
keyFrame.Parent = screenGui
Instance.new("UICorner", keyFrame).CornerRadius = UDim.new(0, 10)

local keyStroke = Instance.new("UIStroke")
keyStroke.Color = Color3.fromRGB(0, 170, 255)
keyStroke.Thickness = 1.5
keyStroke.Transparency = 0.7
keyStroke.Parent = keyFrame

local keyBox = Instance.new("TextBox")
keyBox.Size = UDim2.new(0.55, 0, 1, 0)
keyBox.Position = UDim2.new(0, 8, 0, 0)
keyBox.BackgroundTransparency = 1
keyBox.Text = ""
keyBox.PlaceholderText = "Key..."
keyBox.TextColor3 = Color3.fromRGB(255, 255, 255)
keyBox.PlaceholderColor3 = Color3.fromRGB(130, 130, 130)
keyBox.Font = Enum.Font.GothamBold
keyBox.TextSize = 13
keyBox.ClearTextOnFocus = true
keyBox.Parent = keyFrame

local applyBtn = Instance.new("TextButton")
applyBtn.Size = UDim2.new(0.4, -4, 0.7, 0)
applyBtn.Position = UDim2.new(0.6, 0, 0.15, 0)
applyBtn.BackgroundColor3 = Color3.fromRGB(0, 170, 255)
applyBtn.Text = "SET"
applyBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
applyBtn.Font = Enum.Font.GothamBold
applyBtn.TextSize = 11
applyBtn.AutoButtonColor = false
applyBtn.Parent = keyFrame
Instance.new("UICorner", applyBtn).CornerRadius = UDim.new(0, 6)

local function syncKeyFrame()
	keyFrame.Position = UDim2.new(
		0, button.Position.X.Offset,
		0, button.Position.Y.Offset + 62
	)
end

local function clampPosition(pos)
	local guiSize = screenGui.AbsoluteSize
	local bSize = button.AbsoluteSize
	local x = math.clamp(pos.X.Offset, 0, guiSize.X - bSize.X)
	local y = math.clamp(pos.Y.Offset, 0, guiSize.Y - bSize.Y)
	return UDim2.new(0, x, 0, y)
end

local function setState(state)
	toggled = state

	if toggled then
		tweenService:Create(button, TweenInfo.new(0.2), {
			BackgroundColor3 = Color3.fromRGB(0, 170, 255)
		}):Play()
		stroke.Transparency = 0.2
		button.Text = "STATE: ON"
	else
		tweenService:Create(button, TweenInfo.new(0.2), {
			BackgroundColor3 = Color3.fromRGB(35, 35, 35)
		}):Play()
		stroke.Transparency = 0.7
		button.Text = "STATE: OFF"
	end
end

local function toggleState()
	setState(not toggled)
end

applyBtn.MouseButton1Click:Connect(function()
	local txt = keyBox.Text:upper():sub(1, 1)
	if txt == "" then
		keyBox.Text = "?"
		return
	end

	local ok, enumKey = pcall(function()
		return Enum.KeyCode[txt]
	end)

	if ok and enumKey then
		customKey = enumKey
		keyBox.Text = txt
		keyStroke.Color = Color3.fromRGB(0, 255, 100)

		tweenService:Create(applyBtn, TweenInfo.new(0.15), {
			BackgroundColor3 = Color3.fromRGB(0, 200, 80)
		}):Play()

		task.delay(0.8, function()
			tweenService:Create(applyBtn, TweenInfo.new(0.15), {
				BackgroundColor3 = Color3.fromRGB(0, 170, 255)
			}):Play()
			keyStroke.Color = Color3.fromRGB(0, 170, 255)
		end)
	else
		keyBox.Text = "?"
	end
end)

userInputService.InputBegan:Connect(function(input, processed)
	if processed then return end
	if customKey and input.KeyCode == customKey then
		toggleState()
	end
end)

local dragging = false
local didDrag = false
local dragInput = nil
local dragStartPos = nil
local buttonStartPos = nil
local DRAG_THRESHOLD = 12

local function onPressDown()
	tweenService:Create(button, TweenInfo.new(0.08, Enum.EasingStyle.Quad), {
		Size = UDim2.new(0, 112, 0, 48),
		BackgroundTransparency = 0.15,
	}):Play()
end

local function onPressUp()
	tweenService:Create(button, TweenInfo.new(0.12, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {
		Size = UDim2.new(0, 120, 0, 54),
		BackgroundTransparency = 0,
	}):Play()
end

local function updateDrag(input)
	local delta = input.Position - dragStartPos

	if not didDrag and (math.abs(delta.X) > DRAG_THRESHOLD or math.abs(delta.Y) > DRAG_THRESHOLD) then
		didDrag = true
	end

	if didDrag then
		local newPos = UDim2.new(
			0, buttonStartPos.X.Offset + delta.X,
			0, buttonStartPos.Y.Offset + delta.Y
		)
		button.Position = clampPosition(newPos)
		syncKeyFrame()
	end
end

button.InputBegan:Connect(function(input)
	if input.UserInputType ~= Enum.UserInputType.Touch
	and input.UserInputType ~= Enum.UserInputType.MouseButton1 then
		return
	end

	dragging = true
	didDrag = false
	dragStartPos = input.Position
	buttonStartPos = UDim2.new(0, button.Position.X.Offset, 0, button.Position.Y.Offset)

	if input.UserInputType == Enum.UserInputType.Touch then
		dragInput = input
	else
		dragInput = Enum.UserInputType.MouseMovement
	end

	onPressDown()
end)

userInputService.InputChanged:Connect(function(input)
	if not dragging then return end

	if input == dragInput or input.UserInputType == dragInput then
		updateDrag(input)
	end
end)

userInputService.InputEnded:Connect(function(input)
	if not dragging then return end

	local sameTouch = input.UserInputType == Enum.UserInputType.Touch and input == dragInput
	local sameMouse = input.UserInputType == Enum.UserInputType.MouseButton1

	if not sameTouch and not sameMouse then
		return
	end

	dragging = false
	dragInput = nil
	onPressUp()

	if not didDrag then
		toggleState()
	end
end)

syncKeyFrame()
setState(false)
