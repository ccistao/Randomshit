local player = game.Players.LocalPlayer
local runService = game:GetService("RunService")
local userInputService = game:GetService("UserInputService")
local tweenService = game:GetService("TweenService")

-- CẤU HÌNH TÙY CHỈNH
local BIND_KEY = Enum.KeyCode.F -- Bạn có thể đổi phím tại đây

local isBlinking = false
local fakeChar = nil
local connection = nil
local startCFrame = nil

local screenGui = Instance.new("ScreenGui")
screenGui.Name = "Blink_V5_PC_Mobile"
screenGui.Parent = player:WaitForChild("PlayerGui")
screenGui.ResetOnSpawn = false

local button = Instance.new("TextButton")
button.Size = UDim2.new(0, 120, 0, 54)
button.Position = UDim2.new(0.5, -60, 0.2, 0)
button.BackgroundColor3 = Color3.fromRGB(35, 35, 35)
button.Text = "BLINK: OFF"
button.TextColor3 = Color3.fromRGB(255, 255, 255)
button.Font = Enum.Font.GothamBold
button.TextSize = 16
button.ClipsDescendants = true
button.AutoButtonColor = false
button.Parent = screenGui
Instance.new("UICorner", button).CornerRadius = UDim.new(0, 14)

local stroke = Instance.new("UIStroke")
stroke.Color = Color3.fromRGB(0, 170, 255)
stroke.Thickness = 1.5
stroke.Transparency = 0.7
stroke.Parent = button

-- BIẾN HỖ TRỢ DRAG
local dragging = false
local didDrag = false
local dragInput = nil
local dragStartPos = nil
local buttonStartPos = nil
local DRAG_THRESHOLD = 5 -- Độ nhạy kéo (thấp hơn để PC nhạy hơn)

-- HÀM TOGGLE BLINK (Đưa lên trên để các event gọi được)
local function toggleBlink()
    local realChar = player.Character
    if not realChar or not realChar:FindFirstChild("HumanoidRootPart") then return end
    local realRoot = realChar.HumanoidRootPart
    local realHum = realChar:FindFirstChildOfClass("Humanoid")

    isBlinking = not isBlinking

    if isBlinking then
        tweenService:Create(button, TweenInfo.new(0.2), {BackgroundColor3 = Color3.fromRGB(0, 170, 255)}):Play()
        stroke.Transparency = 0.2
        button.Text = "BLINK: ON"

        startCFrame = realRoot.CFrame
        realChar.Archivable = true
        fakeChar = realChar:Clone()
        fakeChar.Parent = workspace

        local fakeHum = fakeChar:FindFirstChildOfClass("Humanoid")
        if fakeHum and realHum then
            fakeHum:ApplyDescription(realHum:GetAppliedDescription())
        end

        for _, p in pairs(fakeChar:GetDescendants()) do
            if p:IsA("BasePart") then
                p.CanCollide = false
                p.Transparency = (p.Name == "HumanoidRootPart") and 1 or 0.3 -- Làm mờ bóng ma một chút
            elseif p:IsA("SelectionBox") or p:IsA("SelectionPartLasso") then
                p:Destroy()
            end
        end

        local bp = Instance.new("BodyPosition")
        bp.Position = startCFrame.Position
        bp.MaxForce = Vector3.new(math.huge, math.huge, math.huge)
        bp.D = 1000; bp.P = 10000; bp.Parent = realRoot

        local bg = Instance.new("BodyGyro")
        bg.CFrame = startCFrame
        bg.MaxTorque = Vector3.new(math.huge, math.huge, math.huge)
        bg.Parent = realRoot

        workspace.CurrentCamera.CameraSubject = fakeChar:FindFirstChildOfClass("Humanoid")

        connection = runService.RenderStepped:Connect(function()
            if fakeChar and fakeChar:FindFirstChild("Humanoid") then
                fakeChar.Humanoid:Move(realHum.MoveDirection, false)
                if realHum.Jump then fakeChar.Humanoid.Jump = true end
            end
        end)
    else
        tweenService:Create(button, TweenInfo.new(0.2), {BackgroundColor3 = Color3.fromRGB(35, 35, 35)}):Play()
        stroke.Transparency = 0.7
        button.Text = "BLINK: OFF"

        if connection then connection:Disconnect() end
        if realRoot:FindFirstChildOfClass("BodyPosition") then realRoot:FindFirstChildOfClass("BodyPosition"):Destroy() end
        if realRoot:FindFirstChildOfClass("BodyGyro") then realRoot:FindFirstChildOfClass("BodyGyro"):Destroy() end

        if fakeChar and fakeChar:FindFirstChild("HumanoidRootPart") then
            realRoot.CFrame = fakeChar.HumanoidRootPart.CFrame
            fakeChar:Destroy()
            fakeChar = nil
            workspace.CurrentCamera.CameraSubject = realHum
        end
    end
end

-- LOGIC DRAGGING (PC & MOBILE)
local function clampPosition(pos)
    local guiSize = screenGui.AbsoluteSize
    local bSize = button.AbsoluteSize
    local x = math.clamp(pos.X.Offset, 0, guiSize.X - bSize.X)
    local y = math.clamp(pos.Y.Offset, 0, guiSize.Y - bSize.Y)
    return UDim2.new(0, x, 0, y)
end

button.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        dragging = true
        didDrag = false
        dragStartPos = input.Position
        buttonStartPos = button.Position
        
        input.Changed:Connect(function()
            if input.UserInputState == Enum.UserInputState.End then
                dragging = false
                tweenService:Create(button, TweenInfo.new(0.12, Enum.EasingStyle.Back), {Size = UDim2.new(0, 120, 0, 54)}):Play()
            end
        end)
        
        tweenService:Create(button, TweenInfo.new(0.08), {Size = UDim2.new(0, 112, 0, 48)}):Play()
    end
end)

userInputService.InputChanged:Connect(function(input)
    if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
        local delta = input.Position - dragStartPos
        if math.abs(delta.X) > DRAG_THRESHOLD or math.abs(delta.Y) > DRAG_THRESHOLD then
            didDrag = true
        end
        if didDrag then
            button.Position = clampPosition(UDim2.new(buttonStartPos.X.Scale, buttonStartPos.X.Offset + delta.X, buttonStartPos.Y.Scale, buttonStartPos.Y.Offset + delta.Y))
        end
    end
end)

button.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        if not didDrag then
            toggleBlink()
        end
    end
end)

-- LOGIC KEYBIND CHO PC
userInputService.InputBegan:Connect(function(input, gameProcessed)
    if gameProcessed then return end -- Không kích hoạt khi đang chat
    if input.KeyCode == BIND_KEY then
        toggleBlink()
    end
end)
