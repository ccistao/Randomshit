-- HELPERS: GAME STATE
-- ============================================================
local LOBBY_MIN = Vector3.new(14, -5, -478)
local LOBBY_MAX = Vector3.new(227, 50, -264)

local function isInLobby()
    local char = player.Character
    if not char then return true end
    local root = char:FindFirstChild("HumanoidRootPart")
    if not root then return true end
    local p = root.Position
    return p.X >= LOBBY_MIN.X and p.X <= LOBBY_MAX.X
       and p.Y >= LOBBY_MIN.Y and p.Y <= LOBBY_MAX.Y
       and p.Z >= LOBBY_MIN.Z and p.Z <= LOBBY_MAX.Z
end

local function isInGame() return not isInLobby() end

local function isFindExitPhase()
    local gs  = ReplicatedStorage:FindFirstChild("GameStatus")
    local txt = gs and tostring(gs.Value):upper() or ""
    if txt:find("FIND") and txt:find("EXIT") then return true end
    local found = false
    pcall(function()
        local pg  = player:FindFirstChild("PlayerGui")
        local sg  = pg  and pg:FindFirstChild("ScreenGui")
        local gif = sg  and sg:FindFirstChild("GameInfoFrame")
        local gsb = gif and gif:FindFirstChild("GameStatusBox")
        if gsb then
            local t = gsb.Text:upper()
            if t:find("FIND") and t:find("EXIT") then found = true end
        end
    end)
    return found
end

local function isGameActive()
    local gs  = ReplicatedStorage:FindFirstChild("GameStatus")
    local txt = gs and tostring(gs.Value):upper() or ""
    if txt:find("HEAD START") then return true end
    if isInLobby() then return false end
    if txt:find("GAME OVER") or txt:find("BEAST LEFT")
    or txt:find("BEF LAI")   or txt:find("KET THUC")
    or txt:find("TRO CHOI KET THUC") then return false end
    return true
end

local function hasPlayerEscaped()
    local st = player:FindFirstChild("TempPlayerStatsModule")
    if not st then return false end
    local f = st:FindFirstChild("Escaped")
    return f and f.Value == true
end

local function getPlayerActionProgress()
    local st = player:FindFirstChild("TempPlayerStatsModule")
    if not st then return 0 end
    local p = st:FindFirstChild("ActionProgress")
    return p and (p:IsA("IntValue") or p:IsA("NumberValue")) and p.Value or 0
end

