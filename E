local function isBeast(p)
    local st = p:FindFirstChild("TempPlayerStatsModule")
    if not st then return false end
    local f = st:FindFirstChild("IsBeast")
    return f and f.Value == true
end

local function isSelfBeast() return isBeast(player) end

local function isBeastNearby(dist)
    dist = dist or 32
    if not foundBeast or not beast or not beast.Character then return false end
    local br = beast.Character:FindFirstChild("HumanoidRootPart")
            or beast.Character:FindFirstChild("UpperTorso")
            or beast.Character:FindFirstChild("Torso")
    local my = rootPart or (player.Character and player.Character:FindFirstChild("HumanoidRootPart"))
    if not br or not my then return false end
    return (my.Position - br.Position).Magnitude <= dist
end

local function isSelfCaged()
    local char = player.Character
    if not char then return false end
    local selfTorso = char:FindFirstChild("UpperTorso") or char:FindFirstChild("Torso")
    if not selfTorso then return false end
    local mapVal = ReplicatedStorage:FindFirstChild("CurrentMap")
    mapVal = mapVal and mapVal.Value
    if not mapVal then return false end
    for _, v in ipairs(mapVal:GetChildren()) do
        if v.Name == "FreezePod" then
            local ct = v:FindFirstChild("CapturedTorso", true)
            if ct and ct.Value == selfTorso then return true end
        end
    end
    return false
end

