-- Webhook config (sống trong GUI scope nhưng ref qua _G)
-- Được set bởi GUI và đọc bởi logic

local function saveConfig()
    pcall(function()
        local HttpService = game:GetService("HttpService")
        writefile(CONFIG_FILE, HttpService:JSONEncode({
            tweenSpeed      = tweenSpeed,
            webhookUrl      = _G.ftfWebhookUrl      or "",
            webhookInterval = _G.ftfWebhookInterval or 5,
            hackExtraPC     = _G.ftfHackExtraPC     or false,
            altCageDelay    = altCageDelay,
            autoSendEnabled = _G.ftfAutoSend        or false,
            pingDisconEnabled = _G.ftfPingDiscon    or false,
            pingUserId      = _G.ftfPingUserId      or "",
        }))
    end)
end

local function loadConfig()
    pcall(function()
        if not isfile(CONFIG_FILE) then return end
        local HttpService = game:GetService("HttpService")
        local ok, cfg = pcall(function() return HttpService:JSONDecode(readfile(CONFIG_FILE)) end)
        if not ok or not cfg then return end
        if cfg.tweenSpeed      then tweenSpeed      = math.clamp(cfg.tweenSpeed, 10, 45) end
        if cfg.altCageDelay    then altCageDelay    = math.clamp(cfg.altCageDelay, 10, 300) end
        _G.ftfWebhookUrl      = cfg.webhookUrl      or ""
        _G.ftfWebhookInterval = cfg.webhookInterval or 5
        _G.ftfAutoSend        = cfg.autoSendEnabled or false
        _G.ftfHackExtraPC     = cfg.hackExtraPC     or false
        _G.ftfPingDiscon      = cfg.pingDisconEnabled or false
        _G.ftfPingUserId      = cfg.pingUserId      or ""
        hackExtraPC = _G.ftfHackExtraPC
    end)
end

loadConfig()

