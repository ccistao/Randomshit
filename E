    local function consoleLog(msg, logType)
        logOrder += 1
        local color, prefix
        if logType == "warn" then color = Color3.fromRGB(255,200,50); prefix = "⚠ "
        elseif logType == "error" then color = Color3.fromRGB(255,80,80); prefix = "✖ "
        elseif logType == "status" then color = Color3.fromRGB(100,200,255); prefix = "» "
        else color = Color3.fromRGB(160,230,160); prefix = "" end
        local lbl = Instance.new("TextLabel", consoleScroll)
        lbl.Size = UDim2.new(1,0,0,LINE_H); lbl.BackgroundTransparency = 1
        lbl.Text = prefix..tostring(msg); lbl.TextColor3 = color
        lbl.TextSize = 13; lbl.Font = Enum.Font.Code
        lbl.TextXAlignment = Enum.TextXAlignment.Left
        lbl.TextTruncate = Enum.TextTruncate.AtEnd; lbl.LayoutOrder = logOrder; lbl.ZIndex = 11
        table.insert(labelQueue, lbl)
        while #labelQueue > maxLogLines do
            local old = table.remove(labelQueue, 1)
            if old and old.Parent then old:Destroy() end
        end
        task.defer(function()
            local totalH = consoleLayout.AbsoluteContentSize.Y + 4
            consoleScroll.CanvasSize = UDim2.new(0,0,0,totalH)
            consoleScroll.CanvasPosition = Vector2.new(0, math.max(0, totalH-consoleScroll.AbsoluteSize.Y))
        end)
    end

