-- ============================================================
-- LOGGING
-- ============================================================
local logBuffer    = {}
local MAX_BUFFER   = 200
local consoleLogFn = nil

local function bufferedLog(msg, logType)
    if consoleLogFn then
        consoleLogFn(msg, logType)
    else
        table.insert(logBuffer, {msg = tostring(msg), logType = logType or "normal"})
        if #logBuffer > MAX_BUFFER then table.remove(logBuffer, 1) end
    end
end

local function log(msg, logType)
    bufferedLog(tostring(msg), logType or "normal")
end

local statusLabel = nil
local _lastStatus = ""
local function updateStatus(s)
    s = tostring(s)
    if statusLabel then statusLabel.Text = "Status: " .. s end
    if s ~= _lastStatus then
        _lastStatus = s
        bufferedLog(s, "status")
    end
end

