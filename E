-- ===== LOG BUFFER =====
local logBuffer = {}
local MAX_BUFFER = 200
local consoleLogFn = nil

local function bufferedLog(msg, logType)
    if consoleLogFn then
        consoleLogFn(msg, logType)
    else
        table.insert(logBuffer, {msg = tostring(msg), logType = logType or "normal"})
        if #logBuffer > MAX_BUFFER then table.remove(logBuffer, 1) end
    end
end

-- log: luôn tạo dòng mới trong console
local function log(msg)
    bufferedLog(tostring(msg), "normal")
end

-- updateStatus: update label + chỉ log khi text thay đổi
local _lastStatus = ""
local function updateStatus(status)
    local s = tostring(status)
    if statusLabel then
        statusLabel.Text = "Status: " .. s
    end
    if s ~= _lastStatus then
        _lastStatus = s
        bufferedLog(s, "status")
    end
end

