local allPCs    = {}
local hackedPCs = {}
local skippedPCs = {}
local coHackProgressCache = {}

local function findAllPCs()
    local found = {}
    local map = ReplicatedStorage:FindFirstChild("CurrentMap")
    map = map and map.Value
    if not map then return found end
    for _, obj in ipairs(map:GetDescendants()) do
        if obj:IsA("Model") or obj:IsA("Folder") then
            local nl = obj.Name:lower()
            if nl:find("computer") and not nl:find("prefab") then
                local triggers = {}
                for _, t in ipairs(obj:GetDescendants()) do
                    if t:IsA("BasePart") and (t.Name == "ComputerTrigger1"
                    or t.Name == "ComputerTrigger2" or t.Name == "ComputerTrigger3") then
                        table.insert(triggers, t)
                    end
                end
                if #triggers == 3 then
                    table.insert(found, {computer = obj, triggers = triggers})
                end
            end
        end
    end
    for i, pc in ipairs(found) do pc.id = i end
    return found
end

local function getPCProgress(pcData)
    if not pcData or not pcData.computer then return 0 end
    local pc = pcData.computer
    if not pc or not pc.Parent then return 0 end
    local screen = pc:FindFirstChild("Screen")
    if screen and screen:IsA("BasePart") then
        local c = screen.Color
        if c.G > c.R + 0.2 and c.G > c.B + 0.2 then return 1 end
    end
    local maxVal = 0
    for _, v in ipairs(pc:GetDescendants()) do
        if v and (v:IsA("IntValue") or v:IsA("NumberValue")) then
            local val = tonumber(v.Value) or 0
            if (v.Name == "ActionProgress" or v.Name == "Value") and val > maxVal then
                maxVal = val
            end
        end
    end
    return maxVal
end

local function isScreenGreen(pcData)
    if not pcData or not pcData.computer then return false end
    local screen = pcData.computer:FindFirstChild("Screen")
    if not screen then
        for _, v in ipairs(pcData.computer:GetDescendants()) do
            if v.Name == "Screen" and v:IsA("BasePart") then screen = v break end
        end
    end
    if screen and screen:IsA("BasePart") then
        local c = screen.Color
        return c.G > c.R + 0.2 and c.G > c.B + 0.2
    end
    return false
end

-- isCoHacking: check trực tiếp, không qua tracker delay
local function isCoHacking()
    if not currentPC or not isHacking then return false end
    for _, other in ipairs(Players:GetPlayers()) do
        if other == player or not other.Character then continue end
        local otherRoot = other.Character:FindFirstChild("HumanoidRootPart")
        if not otherRoot then coHackProgressCache[other.Name] = nil; continue end
        local isNear = false
        for _, trigger in ipairs(currentPC.triggers) do
            if (otherRoot.Position - trigger.Position).Magnitude <= 7 then
                isNear = true; break
            end
        end
        if not isNear then coHackProgressCache[other.Name] = nil; continue end
        local tps = other:FindFirstChild("TempPlayerStatsModule")
        local ap  = tps and tps:FindFirstChild("ActionProgress")
        if not ap then continue end
        local cur  = ap.Value
        local last = coHackProgressCache[other.Name]
        if last == nil then coHackProgressCache[other.Name] = cur; continue end
        coHackProgressCache[other.Name] = cur
        if cur > last + 0.001 then return true end
    end
    return false
end

