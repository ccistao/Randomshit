                for _, v in ipairs(mapV:GetChildren()) do
                    if v.Name == "FreezePod" then
                        local ct = v:FindFirstChild("CapturedTorso", true)
                        if ct and ct.Value == t3 then targetCaged = true break end
                    end
                end
            end)
            if targetCaged then log("👹 " .. target.Name .. " in FreezePod!"); break end
            -- Timeout 2s không ragdoll → skip
            ragdollTimer += 0.05
            if ragdollTimer >= 2 then
                local h3 = target.Character and target.Character:FindFirstChild("Humanoid")
                if h3 and not h3.PlatformStand then
                    log("👹 " .. target.Name .. " không ragdoll 2s → skip"); break
                end
            end
            local t2 = target.Character:FindFirstChild("UpperTorso") or target.Character:FindFirstChild("Torso")
            if t2 then root.CFrame = CFrame.new(t2.Position + Vector3.new(0, 0, 0.5)) end
            remote:FireServer("HammerClick", true)
            remote:FireServer("HammerHit", torso)
            task.wait(0.05); hitTimer += 0.05
        end
    end
