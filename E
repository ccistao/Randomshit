-- ============================================================
-- AUTO EXIT
-- ============================================================
local hasEscaped = false

local function autoExitUnified()
    setState("exiting")
    updateStatus("Auto Exit started!")

    local char = player.Character
    local hum  = char and char:FindFirstChild("Humanoid")
    if hum then
        log("🚪 Jump to cancel PC hack...")
        isHacking = false; canAutoJump = false; currentTrigger = nil
        hum:ChangeState(Enum.HumanoidStateType.Jumping)
        task.wait(0.2)
    end

    local function findExits()
        local exits = {}
        local map = ReplicatedStorage:FindFirstChild("CurrentMap")
        map = map and map.Value
        if not map then return exits end
        for _, obj in ipairs(map:GetDescendants()) do
            if obj:IsA("Model") and obj.Name == "ExitDoor" then
                local trig = obj:FindFirstChild("ExitDoorTrigger", true)
                local area = obj:FindFirstChild("ExitArea", true)
                if trig then table.insert(exits, {model=obj, trigger=trig, area=area or trig}) end
            end
        end
        return exits
    end

    local function tpFront(trigger)
        local c = player.Character; if not c then return end
        local r = c:FindFirstChild("HumanoidRootPart"); if not r then return end
        r.CanCollide = false
        r.AssemblyLinearVelocity = Vector3.zero
        r.AssemblyAngularVelocity = Vector3.zero
        r.CFrame = CFrame.new(trigger.Position.X, trigger.Position.Y + 2.5, trigger.Position.Z)
        task.delay(0.5, function() if r then r.CanCollide = true end end)
    end

    local function getActionProgress(plr)
        local tps = plr:FindFirstChild("TempPlayerStatsModule")
        local ap  = tps and tps:FindFirstChild("ActionProgress")
        return ap and ap.Value or 0
    end

    local function getPlayerOpeningDoor(trigger)
        for _, p in ipairs(Players:GetPlayers()) do
            if p ~= player and p.Character then
                local r = p.Character:FindFirstChild("HumanoidRootPart")
                if r and (r.Position - trigger.Position).Magnitude <= 8 then return p end
            end
        end
        return nil
    end

    local function waitForDoorOpen(exitData, timeoutSecs)
        timeoutSecs = timeoutSecs or 20
        local waited = 0; local beastInterrupted = false
        local prevProg = 0; local peakProg = 0
        while waited < timeoutSecs do
            task.wait(0.05); waited += 0.05
            if isBeastNearby(35) then
                log("👹 [EXIT] Beast cách khi mở cửa → chuyển exit")
                beastInterrupted = true; break
            end
            if not scriptEnabled then return false, false end
            if hasEscaped or hasPlayerEscaped() then hasEscaped = true return true, false end
            local prog = getActionProgress(player)
            if prog > peakProg then peakProg = prog end
            if peakProg >= 0.95 and prog < prevProg - 0.05 then return true, false end
            if prog >= 0.999 then return true, false end
            prevProg = prog
        end
        return false, beastInterrupted
    end

    local function escape(exitData)
        local c = player.Character; if not c then return end
        local r = c:FindFirstChild("HumanoidRootPart"); if not r then return end
        if not exitData.area then return end
        local hum = c:FindFirstChild("Humanoid")

        log("[ESCAPE] Bắt đầu thoát! TP xuống -80 để trigger server...")
        -- TP xuống -80 rồi freeze 1.5s để server nhận
        local myPos = r.Position
        r.CFrame = CFrame.new(myPos.X, myPos.Y - 80, myPos.Z)
        if hum then
            hum.PlatformStand = true
            hum:ChangeState(Enum.HumanoidStateType.Physics)
        end
        local fzActive = true
        local fzConn = RunService.Heartbeat:Connect(function()
            if not fzActive then return end
            pcall(function()
                r.AssemblyLinearVelocity = Vector3.zero
                r.AssemblyAngularVelocity = Vector3.zero
            end)
        end)
        task.wait(1.5)
        fzActive = false; fzConn:Disconnect()

        -- TP vào ExitArea
        r.CFrame = exitData.area.CFrame + Vector3.new(0, 2, 0)
        task.wait(0.3)
        if hum then
            hum.PlatformStand = false
            hum:ChangeState(Enum.HumanoidStateType.GettingUp)
        end

        -- Spam remote + retry TP mỗi 1s cho tới khi thoát (tối đa 20s)
        local waitTime = 0
        while waitTime < 20 do
            task.wait(0.2); waitTime += 0.2
            if hasPlayerEscaped() or isInLobby() then
                log("🎉 [ESCAPE] Thoát thành công!")
                hasEscaped = true; return
            end
            pcall(function()
                local re = ReplicatedStorage:FindFirstChild("RemoteEvent")
                if re then re:FireServer("Input", "Action", true) end
            end)
            if waitTime % 1 < 0.2 then
                r.CFrame = exitData.area.CFrame + Vector3.new(0, 2, 0)
                r.AssemblyLinearVelocity = Vector3.zero
            end
        end
        log("⏱ [ESCAPE] Timeout 20s → coi như đã thoát")
        hasEscaped = true
    end

    local lastExitUsed = nil
    local exits = findExits()
    local maxWait = 0

    while scriptEnabled and not hasEscaped and maxWait < 60 do
        task.wait(0.3); maxWait += 0.3
        if not isGameActive() and not isFindExitPhase() then break end
        exits = findExits()
        if #exits == 0 then continue end

        local targetExit = exits[1]
        if lastExitUsed and #exits > 1 then
            for _, e in ipairs(exits) do
                if e.model ~= lastExitUsed then targetExit = e break end
            end
        end

        local otherOpener = getPlayerOpeningDoor(targetExit.trigger)
        if otherOpener then
            log("🤝 " .. otherOpener.Name .. " đang mở cửa...")
            tpFront(targetExit.trigger)
            local opened, beastInt = waitForDoorOpen(targetExit, 20)
            if opened then escape(targetExit); lastExitUsed = targetExit.model end
            if beastInt then
                for _, e in ipairs(exits) do
                    if e.model ~= targetExit.model then targetExit = e break end
                end
            end
        else
            tpFront(targetExit.trigger)
            task.wait(0.2)
            pcall(function()
                safeFire(rootPart, targetExit.trigger, 0)
                task.wait(0.1)
                safeFire(rootPart, targetExit.trigger, 1)
            end)
            local firing = true
            local lastLogProg = -1
            task.spawn(function()
                while firing do
                    task.wait(0.05)
                    pcall(function()
                        local r2 = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
                        if r2 then safeFire(r2, targetExit.trigger, 0); safeFire(r2, targetExit.trigger, 1) end
                        local re = ReplicatedStorage:FindFirstChild("RemoteEvent")
                        if re then re:FireServer("Input", "Action", true) end
                    end)
                    local prog = getActionProgress(player)
                    local pct = math.floor(prog * 10) * 10
                    if pct ~= lastLogProg and pct > 0 then lastLogProg = pct; log("🚪 Mở cửa: " .. pct .. "%") end
                end
            end)
            local opened, beastInt = waitForDoorOpen(targetExit, 20)
            firing = false
            if beastInt then
                log("👹 [EXIT] Beast tới! Chuyển exit khác...")
                for _, e in ipairs(exits) do
                    if e.model ~= targetExit.model then targetExit = e break end
                end
                lastExitUsed = nil
            elseif opened then
                escape(targetExit)
                lastExitUsed = targetExit.model
                if hasEscaped then break end
            else
                log("⏱ Door timeout, thử exit khác...")
                lastExitUsed = targetExit.model
            end
        end
    end
end

-- ============================================================
-- AUTO SAVE (SURVIVOR)
-- ============================================================
local savesThisRound = 0
local maxSaves       = 1

local function autoSaveLoop()
    while true do
        task.wait(0.3)
        if not scriptEnabled or isSelfBeast() then continue end
        if savesThisRound >= maxSaves then continue end
        if isSaving then continue end  -- đang save rồi thì skip
        if roundsPlayed == 0 or not isGameActive() then continue end

        local map = ReplicatedStorage:FindFirstChild("CurrentMap")
        map = map and map.Value
        if not map then continue end
        local root = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
        if not root then continue end

        for _, v in ipairs(map:GetChildren()) do
            if v.Name == "FreezePod" then
                local ct      = v:FindFirstChild("CapturedTorso", true)
                local trigger = v:FindFirstChild("PodTrigger", true)
                if not (ct and ct.Value ~= nil and trigger) then continue end

                local capturedPlayer = nil
                for _, p in ipairs(Players:GetPlayers()) do
                    if p ~= player and p.Character then
                        local torso = p.Character:FindFirstChild("UpperTorso") or p.Character:FindFirstChild("Torso")
                        if torso and ct.Value == torso then capturedPlayer = p break end
                    end
                end
                if not capturedPlayer then continue end

                -- Bắt đầu save - tắt beast check từ đây
                isSaving       = true
                isReturning    = true  -- block beast check trong suốt quá trình save + return
                isMoving       = true
                local savedCanJump = canAutoJump
                canAutoJump = false
                log("🚑 [SAVE] " .. capturedPlayer.Name)
                updateStatus("Saving: " .. capturedPlayer.Name)

                -- Lưu trạng thái để return sau
                local wasHacking     = isHacking
                local returnTrigger  = currentTrigger
                local returnPC       = currentPC
                if not returnTrigger and returnPC and returnPC.triggers and #returnPC.triggers > 0 then
                    returnTrigger = returnPC.triggers[1]
                end

                local cageCenter = v:GetModelCFrame().Position
                local dirIn = (cageCenter - trigger.Position)
                if dirIn.Magnitude > 0 then dirIn = dirIn.Unit * 3 else dirIn = Vector3.zero end
                local savePos = Vector3.new(trigger.Position.X + dirIn.X, trigger.Position.Y, trigger.Position.Z + dirIn.Z)

                local char = player.Character
                local hum  = char and char:FindFirstChild("Humanoid")
                if hum then hum.PlatformStand = true hum:ChangeState(Enum.HumanoidStateType.Physics) end

                -- Noclip
                local ncActive = true
                local ncParts  = {}
                pcall(function()
                    for _, p in pairs(player.Character:GetDescendants()) do
                        if p:IsA("BasePart") then table.insert(ncParts, p) end
                    end
                end)
                local ncConn = RunService.Stepped:Connect(function()
                    if not ncActive or not scriptEnabled then return end
                    for _, p in ipairs(ncParts) do if p and p.Parent then p.CanCollide = false end end
                end)

                root.CFrame = CFrame.new(savePos)
                root.AssemblyLinearVelocity = Vector3.zero
                root.AssemblyAngularVelocity = Vector3.zero
                task.wait(0.15)

                -- Freeze position
                local fzActive = true
                local fzConn = RunService.Heartbeat:Connect(function()
                    if not fzActive or not scriptEnabled then return end
                    pcall(function()
                        root.CFrame = CFrame.new(savePos)
                        root.AssemblyLinearVelocity = Vector3.zero
                        root.AssemblyAngularVelocity = Vector3.zero
                    end)
                end)

                local t = 0
                while t < 3 do
                    pcall(function()
                        safeFire(root, trigger, 0); task.wait(0.03); safeFire(root, trigger, 1)
                    end)
                    pcall(function()
                        local r = ReplicatedStorage:FindFirstChild("RemoteEvent")
                        if r then r:FireServer("Input", "Action", true) end
                    end)
                    ct = v:FindFirstChild("CapturedTorso", true)
                    if ct and ct.Value == nil then
                        savesThisRound += 1
                        log("✅ [SAVE] Đã cứu " .. capturedPlayer.Name .. "! Saves=" .. savesThisRound)
                        updateStatus("Saved! Returning to PC...")
                        break
                    end
                    task.wait(0.15); t += 0.18
                end

                fzActive = false; fzConn:Disconnect()
                ncActive = false; ncConn:Disconnect()
                if hum then hum.PlatformStand = false hum:ChangeState(Enum.HumanoidStateType.GettingUp) end

                canAutoJump  = savedCanJump
                isSaving     = false
                isMoving     = false
                isHacking    = false
                currentTrigger = nil
                skippedPCs   = {}

                if not isGameActive() or gameOver then
                    isReturning = false
                    break
                end

                -- Return về PC cũ
                if returnPC then
                    log("🔄 Return về PC" .. tostring(returnPC.id) .. " | wasHacking=" .. tostring(wasHacking))
                    local retTok = scriptToken
                    isReturning = true

                    if wasHacking then
                        -- Đang hack lúc save → TP thẳng về trigger NGAY rồi hackPC
                        updateStatus("Returning to PC " .. tostring(returnPC.id) .. "...")
                        if returnTrigger then
                            pcall(function()
                                local r = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
                                if r then
                                    r.CFrame = returnTrigger.CFrame + Vector3.new(0, 0.5, 0)
                                    r.AssemblyLinearVelocity = Vector3.zero
                                end
                            end)
                        end
                        task.spawn(function()
                            if not isGameActive() or gameOver then isReturning = false return end
                            hackPC(returnPC, retTok, true)
                            isReturning = false
                            isHacking   = false
                        end)
                    else
                        -- Đang tween lúc save → clear isReturning ngay, mainLoop tự tween tiếp
                        -- Không spawn hackPC, tránh gap giữa return và mainLoop react
                        isReturning = false
                        log("🔄 Was tweening → mainLoop tự tiếp tục")
                    end
                else
                    isReturning = false
                end
                break
            end
        end
    end
end

