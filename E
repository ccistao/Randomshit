-- ==================== HEARTBEAT ====================
local coHackProgressCache = {} -- {[playerName] = lastProgress}

local function isCoHacking()
    if not currentPC then return false end
    for _, other in ipairs(Players:GetPlayers()) do
        if other ~= player and other.Character then
            local root = other.Character:FindFirstChild("HumanoidRootPart")
            if not root then continue end
            -- Check gần bất kỳ trigger nào của PC hiện tại
            local nearAnyTrigger = false
            for _, trigger in ipairs(currentPC.triggers) do
                if (root.Position - trigger.Position).Magnitude <= 8 then
                    nearAnyTrigger = true
                    break
                end
            end
            if not nearAnyTrigger then
                coHackProgressCache[other.Name] = nil
                continue
            end
            -- Check ActionProgress có đang tăng không
            local tps = other:FindFirstChild("TempPlayerStatsModule")
            local ap = tps and tps:FindFirstChild("ActionProgress")
            if not ap then continue end
            local current = ap.Value
            local last = coHackProgressCache[other.Name]
            coHackProgressCache[other.Name] = current
            -- Tăng so với lần check trước AND > 0 = đang hack thật
            if last and current > last and current > 0.01 then
                return true
            end
        end
    end
    return false
end

RunService.Heartbeat:Connect(function(dt)
    local char = player.Character
    if not char then return end
    humanoid = char:FindFirstChild("Humanoid")
    rootPart = char:FindFirstChild("HumanoidRootPart")

    if gameOver then
        canAutoJump = false
        jumpTimer = 0
        return
    end

    if canAutoJump and humanoid and rootPart and currentTrigger then
        if isCoHacking() then
            jumpTimer = 0
            return
        end
        jumpTimer += dt
        if jumpTimer >= jumpInterval then
            pcall(function()
                rootPart.CFrame = CFrame.new(rootPart.CFrame.Position + Vector3.new(0, 7, 0))
            end)
            task.wait(0.07)
            pcall(function()
                rootPart.CFrame = currentTrigger.CFrame + Vector3.new(0, 0.5, 0)
            end)
            jumpTimer = 0
        end
    end
end)

-- ==================== HACK PC ====================
local function hackPC(pcData)
    if not pcData or not pcData.computer or not pcData.triggers or #pcData.triggers == 0 then
        log("hackPC: invalid pcData")
        return false
    end

    local pcId = tostring(pcData.id)
    local pcName = pcData.computer.Name or "Unknown"

    -- ===== HELPER: move tới 1 trigger =====
    local function moveTo(trigger)
        if not rootPart then return end
        local char = player.Character
        if not char then return end
        local hum = char:FindFirstChild("Humanoid")

        if firstMoveOfRound or isReturning then
            firstMoveOfRound = false
            isReturning = false -- clear ngay sau khi TP về, không để ảnh hưởng PC khác
            log("[MOVE] TP thẳng đến PC" .. pcId .. " | lý do: " .. (isReturning and "vừa save" or "first move đầu ván"))
            rootPart.CFrame = trigger.CFrame + Vector3.new(0, 0.5, 0)
            task.wait(0.1)
        else
            while isMoving do task.wait(0.1) end
            isMoving = true
            if hum then
                hum.PlatformStand = true
                hum:ChangeState(Enum.HumanoidStateType.Physics)
            end
            local noclipActive = true
            local noclipConn = RunService.Stepped:Connect(function()
                if not noclipActive then return end
                local c = player.Character
                if not c then return end
                for _, part in pairs(c:GetDescendants()) do
                    if part:IsA("BasePart") then part.CanCollide = false end
                end
            end)
            local function moveToPos(targetPos, spd)
                local STOP_DIST = math.max(0.5, spd * 0.05 * 0.8)
                while true do
                    task.wait(0.05)
                    if isSaving then break end
                    if gameOver or not isGameActive() then break end
                    if not rootPart or not rootPart.Parent then break end
                    local diff = targetPos - rootPart.Position
                    if diff.Magnitude <= STOP_DIST then
                        rootPart.CFrame = CFrame.new(targetPos)
                        rootPart.AssemblyLinearVelocity = Vector3.zero
                        rootPart.AssemblyAngularVelocity = Vector3.zero
                        break
                    end
                    rootPart.AssemblyLinearVelocity = diff.Unit * spd
                    rootPart.AssemblyAngularVelocity = Vector3.zero
                end
            end
            local myPos    = rootPart.Position
            local posDown  = Vector3.new(myPos.X, myPos.Y - 50, myPos.Z)
            local posAcross= Vector3.new(trigger.Position.X, myPos.Y - 50, trigger.Position.Z)
            local posUp    = Vector3.new(trigger.Position.X, trigger.Position.Y + 0.5, trigger.Position.Z)
            moveToPos(posDown, tweenSpeed)
            task.wait(0.05)
            moveToPos(posAcross, math.max(10, tweenSpeed * 0.7))
            task.wait(0.05)
            moveToPos(posUp, tweenSpeed)
            noclipActive = false
            noclipConn:Disconnect()
            if hum then
                hum.PlatformStand = false
                hum:ChangeState(Enum.HumanoidStateType.GettingUp)
            end
            isMoving = false
        end
    end

    -- ===== TWEEN THẲNG tới trigger (dùng khi thử trigger khác trong cùng PC) =====
    local function moveStraightTo(trigger)
        if not rootPart then return end
        local char = player.Character
        if not char then return end
        local hum = char:FindFirstChild("Humanoid")
        while isMoving do task.wait(0.1) end
        isMoving = true
        if hum then
            hum.PlatformStand = true
            hum:ChangeState(Enum.HumanoidStateType.Physics)
        end
        local noclipActive = true
        local noclipConn = RunService.Stepped:Connect(function()
            if not noclipActive then return end
            local c = player.Character
            if not c then return end
            for _, part in pairs(c:GetDescendants()) do
                if part:IsA("BasePart") then part.CanCollide = false end
            end
        end)
        local targetPos = Vector3.new(trigger.Position.X, trigger.Position.Y + 0.5, trigger.Position.Z)
        local STOP_DIST = math.max(0.5, tweenSpeed * 0.05 * 0.8)
        while true do
            task.wait(0.05)
            if isSaving then break end
            if gameOver or not isGameActive() then break end
            if not rootPart or not rootPart.Parent then break end
            local diff = targetPos - rootPart.Position
            if diff.Magnitude <= STOP_DIST then
                rootPart.CFrame = CFrame.new(targetPos)
                rootPart.AssemblyLinearVelocity = Vector3.zero
                rootPart.AssemblyAngularVelocity = Vector3.zero
                break
            end
            rootPart.AssemblyLinearVelocity = diff.Unit * tweenSpeed
            rootPart.AssemblyAngularVelocity = Vector3.zero
        end
        noclipActive = false
        noclipConn:Disconnect()
        if hum then
            hum.PlatformStand = false
            hum:ChangeState(Enum.HumanoidStateType.GettingUp)
        end
        isMoving = false
    end

    log("[PC" .. pcId .. "] Bắt đầu hack | triggers=" .. #pcData.triggers .. " | computer=" .. pcName)
    -- ===== SKIP NGAY NẾU PC ĐÃ DONE (check trước khi move) =====
    local function isScreenGreen()
        -- Check Screen trực tiếp
        local screen = pcData.computer:FindFirstChild("Screen")
        if not screen then
            -- Search descendants
            for _, v in ipairs(pcData.computer:GetDescendants()) do
                if v.Name == "Screen" and v:IsA("BasePart") then
                    screen = v; break
                end
            end
        end
        if screen and screen:IsA("BasePart") then
            local c = screen.Color
            return c.G > c.R + 0.2 and c.G > c.B + 0.2
        end
        return false
    end

    if isScreenGreen() then
        log("✅ [PC" .. pcId .. "] Screen đã xanh (done bởi player khác) → skip")
        hackedPCs[pcData.id] = true
        return true
    end
    local pcProgressNow = getPCProgress(pcData)
    if pcProgressNow >= 1 then
        log("✅ [PC" .. pcId .. "] Progress=" .. math.floor(pcProgressNow*100) .. "% → đã done, skip")
        hackedPCs[pcData.id] = true
        return true
    end

    -- ===== SKIP NẾU FIND EXIT VÀ KHÔNG HACK EXTRA =====
    if isFindExitPhase() and not hackExtraPC then
        log("[PC" .. pcId .. "] Find Exit phase đang chạy + hackExtraPC=false → skip PC này")
        return false
    end

    -- ===== THỬ TỪNG TRIGGER, SKIP PC NẾU KHÔNG CÓ TRIGGER NÀO WORK =====
    local chosenTrigger = nil

    local isFirstTrigger = true
    for _, trigger in ipairs(pcData.triggers) do
        if isSaving then return false end
        if isFirstTrigger then
            isFirstTrigger = false
            moveTo(trigger)       -- U-shape khi tới PC từ xa
        else
            moveStraightTo(trigger) -- Tween thẳng khi thử trigger khác trong cùng PC
        end
        if isSaving then
            isMoving = false
            return false
        end
        currentTrigger = trigger
        canAutoJump = true
        -- Snapshot trước khi fire
        local progressBefore = getPlayerActionProgress()
        -- Spam fire mỗi 0.1s trong 1.6s để chắc server nhận
        pcall(function()
            if trigger and rootPart then
                safeFire(rootPart, trigger, 0)
                task.wait(0.1)
                safeFire(rootPart, trigger, 1)
            end
        end)
        local spamTime = 0
        while spamTime < 1 do
            task.wait(0.1)
            spamTime = spamTime + 0.1
            pcall(function()
                local r = ReplicatedStorage:FindFirstChild("RemoteEvent")
                if r then r:FireServer("Input", "Action", true) end
            end)
        end
        -- Check progress tăng thêm so với trước khi fire
        local progressAfter = getPlayerActionProgress()
        if progressAfter > progressBefore + 0.001 then
            chosenTrigger = trigger
            log("PC" .. pcId .. ": trigger work -> progress=" .. math.floor(progressAfter*100) .. "%")
            break
        else
            log("⚡ PC" .. pcId .. ": trigger " .. _ .. " no response, trying next...")
            canAutoJump = false
            currentTrigger = nil
        end
    end

    if not chosenTrigger then
        log("❌ PC" .. pcId .. ": ALL triggers failed, skipping this PC")
        isMoving = false
        canAutoJump = false
        currentTrigger = nil
        return false
    end

    isHacking = true
    currentPC = pcData
    updateStatus("Hacking PC " .. pcId)

    -- Freeze nhân vật khi hack
    local hackChar = player.Character
    local hackHum = hackChar and hackChar:FindFirstChild("Humanoid")
    local hackRoot = hackChar and hackChar:FindFirstChild("HumanoidRootPart")
    if hackHum then
        hackHum.WalkSpeed = 0
        hackHum.JumpPower = 0
    end
    local freezeHack = true
    local freezeHackConn = RunService.Heartbeat:Connect(function()
        if not freezeHack then return end
        if not isHacking then freezeHack = false return end -- auto-stop nếu không còn hack
        if isMoving then return end -- không freeze khi đang tween/move
        if hackRoot and hackRoot.Parent then
            hackRoot.AssemblyLinearVelocity = Vector3.zero
        end
    end)

    local function unfreezeHack()
        freezeHack = false
        pcall(function() freezeHackConn:Disconnect() end)
        -- Restore từ character hiện tại (có thể đã respawn)
        local curHum = player.Character and player.Character:FindFirstChild("Humanoid")
        if curHum then
            curHum.WalkSpeed = 16
            curHum.JumpPower = 50
        end
        -- Cũng restore từ hackHum gốc nếu còn valid
        if hackHum and hackHum.Parent then
            hackHum.WalkSpeed = 16
            hackHum.JumpPower = 50
        end
    end

    while isHacking and scriptEnabled and not gameOver do
        task.wait(0.15)

        -- Check game còn active không
        if not isGameActive() then
            log("Game ended mid-hack, stopping | status='" .. tostring(ReplicatedStorage:FindFirstChild("GameStatus") and ReplicatedStorage:FindFirstChild("GameStatus").Value or "nil") .. "'")
            isHacking = false
            currentPC = nil
            canAutoJump = false
            currentTrigger = nil
            isMoving = false
            unfreezeHack()
            break
        end

        -- Dừng hack nếu Find Exit phase (và không hack extra)
        if isFindExitPhase() and not hackExtraPC then
            log("[PC" .. pcId .. "] [WARN] Find Exit phase bắt đầu trong khi đang hack → dừng ngay", "warn")
            isHacking = false
            currentPC = nil
            canAutoJump = false
            currentTrigger = nil
            unfreezeHack()
            return false
        end

        -- Beast check (bỏ qua nếu đang save)
        if isBeastNearby(30) and not isSaving and not isReturning then
            isHacking = false
            currentPC = nil
            canAutoJump = false
            skipCurrentPC = true
            if pcData.id then
                skippedPCs[pcData.id] = true
                local _bd = 0
                pcall(function()
                    local _br = beast and beast.Character and (beast.Character:FindFirstChild("HumanoidRootPart") or beast.Character:FindFirstChild("Torso"))
                    if _br and rootPart then _bd = math.floor((rootPart.Position - _br.Position).Magnitude) end
                end)
                log("⚠ [PC" .. pcId .. "] Beast cách " .. _bd .. " studs trong khi hack → skip", "warn")
            end
            unfreezeHack()
            escapeBeast()
            return false
        end

        -- ALT MODE: dừng hack nếu bị nhốt vào cage
        if playerMode == "alt" and isSelfCaged() then
            log("PC" .. pcId .. ": ALT caged, stopping hack")
            isHacking = false
            currentPC = nil
            canAutoJump = false
            currentTrigger = nil
            unfreezeHack()
            return false
        end

        if not pcData.computer or not pcData.computer.Parent then
            log("❌ PC" .. pcId .. ": disappeared from map!")
            unfreezeHack()
            break
        end

        -- Fire action
        pcall(function()
            local remote = ReplicatedStorage:FindFirstChild("RemoteEvent")
            if remote then remote:FireServer("Input", "Action", true) end
        end)

        local prog = getPlayerActionProgress()

        -- Skill check
        if pcData.computer:FindFirstChild("SkillCheckActive")
            and pcData.computer.SkillCheckActive.Value then
            log("⚡ PC" .. pcId .. ": SkillCheck! Firing...")
            pcall(function()
                local hr = ReplicatedStorage:FindFirstChild("RemoteEvent")
                if hr then hr:FireServer("SkillCheck", true) end
            end)
        end

        -- Done check
        local screen = pcData.computer:FindFirstChild("Screen")
        local doneByColor = false
        if screen and screen:IsA("BasePart") then
            local c = screen.Color
            if c.G > c.R + 0.2 and c.G > c.B + 0.2 then doneByColor = true end
        end

        if doneByColor or prog >= 0.999 then
            log("✅ [PC" .. pcId .. "] Hack xong! | isCoHack=" .. tostring(isCoHacking()))
            updateStatus("Done PC " .. pcId)
            hackedPCs[pcData.id] = true

            -- Tắt ngay canAutoJump để tránh loop jump giữ nhân vật ở trigger
            canAutoJump = false
            currentTrigger = nil
            isHacking = false
            currentPC = nil

            allPCs = findAllPCs()
            unfreezeHack()
            return true
        end

    end

    unfreezeHack()
    isHacking = false
    currentPC = nil
    canAutoJump = false
    currentTrigger = nil
    return false
end

-- ==================== AUTO EXIT ====================
local function autoExitUnified()
    local lastExitUsed = nil

    -- Jump để server hủy hack PC (rời trigger), dừng spam fire
    local char = player.Character
    local hum = char and char:FindFirstChild("Humanoid")
    if hum then
        log("🚪 Jump to cancel PC hack...")
        isHacking = false
        canAutoJump = false
        currentTrigger = nil
        hum:ChangeState(Enum.HumanoidStateType.Jumping)
        task.wait(0.2)
    end

    local function findExit()
        local exits = {}
        local mapFolder = ReplicatedStorage:FindFirstChild("CurrentMap")
        local map = mapFolder and mapFolder.Value
        if not map then return exits end
        for _, obj in ipairs(map:GetDescendants()) do
            if obj:IsA("Model") and obj.Name == "ExitDoor" then
                local trig = obj:FindFirstChild("ExitDoorTrigger", true)
                local area = obj:FindFirstChild("ExitArea", true)
                if trig then
                    table.insert(exits, { model = obj, trigger = trig, area = area or trig })
                end
            end
        end
        return exits
    end

    local function canGoExit()
        local gameStatus = ReplicatedStorage:FindFirstChild("GameStatus")
        if gameStatus then
            local statusText = tostring(gameStatus.Value):upper()
            if statusText:find("FIND") and (statusText:find("EXIT") or statusText:find("ESCAPE")) then
                return true
            end
        end
        return false
    end

    local function tpFront(trigger)
        local char = player.Character
        if not char then return end
        local root = char:FindFirstChild("HumanoidRootPart")
        if not root then return end
        root.CanCollide = false
        root.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
        root.AssemblyAngularVelocity = Vector3.new(0, 0, 0)
        root.CFrame = CFrame.new(trigger.Position.X, trigger.Position.Y + 2.5, trigger.Position.Z)
        task.delay(0.5, function() if root then root.CanCollide = true end end)
    end

    local function isExitOpened(exitData)
        return false -- server-side only, không detect được client-side
    end

    -- Lấy ActionProgress của player bất kỳ
    local function getActionProgress(plr)
        local tps = plr:FindFirstChild("TempPlayerStatsModule")
        local ap = tps and tps:FindFirstChild("ActionProgress")
        return ap and ap.Value or 0
    end

    -- Tìm player khác đang đứng gần trigger (đang mở cửa)
    local function getPlayerOpeningDoor(trigger)
        for _, p in ipairs(Players:GetPlayers()) do
            if p ~= player and p.Character then
                local root = p.Character:FindFirstChild("HumanoidRootPart")
                if root and (root.Position - trigger.Position).Magnitude <= 8 then
                    return p
                end
            end
        end
        return nil
    end

    -- Detect door open via ActionProgress
    local function waitForDoorOpen(exitData, timeoutSecs)
        timeoutSecs = timeoutSecs or 20
        local waited = 0
        local beastInterrupted = false
        local prevProg = 0
        local peakProg = 0

        while waited < timeoutSecs do
            task.wait(0.05) -- FIX Bug1: poll nhanh để không miss window 100%
            waited = waited + 0.05

            if isBeastNearby(35) then
                local beastDist = 0
                pcall(function()
                    local br = beast and beast.Character and (
                        beast.Character:FindFirstChild("HumanoidRootPart")
                        or beast.Character:FindFirstChild("Torso"))
                    if br and rootPart then
                        beastDist = math.floor((rootPart.Position - br.Position).Magnitude)
                    end
                end)
                log("👹 [EXIT] Beast cách " .. beastDist .. " studs khi đang mở cửa → chuyển exit khác", "warn")
                beastInterrupted = true
                break
            end

            if isExitOpened(exitData) then
                log("🚪 [EXIT] Cửa mở! (visual check)")
                return true, false
            end

            local otherOpener = getPlayerOpeningDoor(exitData.trigger)
            local prog = 0
            if otherOpener then
                prog = getActionProgress(otherOpener)
            else
                prog = getActionProgress(player)
            end

            peakProg = math.max(peakProg, prog)

            if prog >= 0.999 then
                log("🚪 [EXIT] Cửa mở! (progress 100%)")
                task.wait(0.1)
                return true, false
            end

            -- Detect drop: server reset ActionProgress về 0 sau khi mở cửa thành công
            if prevProg >= 0.7 and prog < 0.1 and peakProg >= 0.7 then
                log("🚪 [EXIT] Cửa mở! (drop detect " .. math.floor(prevProg*100) .. "% → " .. math.floor(prog*100) .. "%)", "warn")
                return true, false
            end

            prevProg = prog
        end

        if not beastInterrupted then
            log("⏱ [EXIT] Timeout " .. timeoutSecs .. "s | peakProg=" .. math.floor(peakProg*100) .. "% → switch exit", "warn")
        end
        return false, beastInterrupted
    end

    local function escape(exitData)
        local char = player.Character
        local root = char and char:FindFirstChild("HumanoidRootPart")
        if not root or not exitData.area then
            return
        end

        local hum = char:FindFirstChild("Humanoid")

        log("[ESCAPE] Bắt đầu thoát! TP xuống để trigger server escape... | exitArea=" .. tostring(exitData.area ~= nil))
        -- TP xuống -80 rồi freeze 2s rồi vào exit area
        local myPos = root.Position
        root.CFrame = CFrame.new(myPos.X, myPos.Y - 80, myPos.Z)

        -- Freeze + zero velocity liên tục để không bị gravity kéo
        if hum then
            hum.PlatformStand = true
            hum:ChangeState(Enum.HumanoidStateType.Physics)
        end
        local freezeActive = true
        local freezeConn = RunService.Heartbeat:Connect(function()
            if not freezeActive then return end
            pcall(function()
                root.AssemblyLinearVelocity = Vector3.zero
                root.AssemblyAngularVelocity = Vector3.zero
            end)
        end)
        task.wait(1.5)
        freezeActive = false
        freezeConn:Disconnect()

        -- TP vào exit area
        root.CFrame = exitData.area.CFrame + Vector3.new(0, 2, 0)
        task.wait(0.3)

        -- Unfreeze
        if hum then
            hum.PlatformStand = false
            hum:ChangeState(Enum.HumanoidStateType.GettingUp)
        end

        -- Spam remote + retry TP liên tục cho tới khi thoát
        local waitTime = 0
        while waitTime < 20 do
            task.wait(0.2)
            waitTime = waitTime + 0.2

            if hasPlayerEscaped() or isInLobby() then
                log("🎉 [ESCAPE] Thoát thành công! hasEscaped=true")
                hasEscaped = true
                return
            end

            -- Spam FireServer để trigger escape
            pcall(function()
                local r = ReplicatedStorage:FindFirstChild("RemoteEvent")
                if r then r:FireServer("Input", "Action", true) end
            end)

            -- Retry TP vào area mỗi 1s
            if waitTime % 1 < 0.2 then
                root.CFrame = exitData.area.CFrame + Vector3.new(0, 2, 0)
                root.AssemblyLinearVelocity = Vector3.zero
            end
        end
        log("⏱ [ESCAPE] Timeout 20s vẫn chưa detect escaped → coi như đã thoát", "warn")
        hasEscaped = true
    end

    local function startOpening(trigger)
        local char = player.Character
        if not char then return false end
        local root = char:FindFirstChild("HumanoidRootPart")
        if not root then return false end
        tpFront(trigger)
        task.wait(0.5)
        pcall(function()
            local r = ReplicatedStorage:FindFirstChild("RemoteEvent")
            if r then
                r:FireServer("Input", "Action", true)
            end
        end)
        return true
    end

    while scriptEnabled and not hasEscaped do
        task.wait(0.2)

        if hasPlayerEscaped() then
            hasEscaped = true
            log("Escaped!")
            break
        end

        if not canGoExit() then
            task.wait(0.3)
            continue
        end

        local exits = findExit()
        if #exits == 0 then
            task.wait(0.5)
            continue
        end

        if #exits == 0 then task.wait(0.5) continue end

        -- Logic chính: ping pong giữa các exit
        if #exits == 0 then task.wait(0.5) continue end

        -- Tìm exit hiện tại không có beast
        local targetExit = nil
        for i, e in ipairs(exits) do
            -- Check beast có gần exit này không (dùng khoảng cách tới trigger)
            local beastChar = beast and beast.Character
            local beastRoot = beastChar and beastChar:FindFirstChild("HumanoidRootPart")
            local beastNearThis = false
            if beastRoot then
                beastNearThis = (beastRoot.Position - e.trigger.Position).Magnitude < 35
            end
            if not beastNearThis then
                targetExit = e
                break
            end
        end

        if not targetExit then
            -- FIX Bug2: Beast chặn tất cả → TP cao lên exit xa nhất + chờ beast rời
            local bestDist = 0
            local beastChar = beast and beast.Character
            local beastRoot = beastChar and beastChar:FindFirstChild("HumanoidRootPart")
            for _, e in ipairs(exits) do
                if beastRoot then
                    local d = (beastRoot.Position - e.trigger.Position).Magnitude
                    if d > bestDist then bestDist = d targetExit = e end
                else
                    targetExit = e
                end
            end
            if targetExit then
                local _c = player.Character
                local _r = _c and _c:FindFirstChild("HumanoidRootPart")
                if _r then
                    _r.CFrame = CFrame.new(
                        targetExit.trigger.Position.X,
                        targetExit.trigger.Position.Y + 35,
                        targetExit.trigger.Position.Z)
                    log("👹 [EXIT] Beast chặn hết " .. #exits .. " exit → TP cao lên exit xa nhất (dist=" .. math.floor(bestDist) .. " studs)", "warn")
                else
                    log("[EXIT] Không tìm được rootPart để tránh beast!", "error")
                end
                updateStatus("👹 Beast blocking exits! Chờ beast rời...")
                local bw = 0
                while isBeastNearby(45) and scriptEnabled and not hasEscaped and bw < 15 do
                    task.wait(0.3)
                    bw = bw + 0.3
                end
                if bw >= 15 then
                    log("[EXIT] Beast vẫn chặn sau 15s → tiếp tục anyway", "warn")
                else
                    log("[EXIT] Beast rời sau " .. string.format("%.1f", bw) .. "s → retry exit")
                end
            end
            continue
        end

        -- Có exit trống -> xử lý bình thường
        if lastExitUsed and targetExit.model == lastExitUsed then
            lastExitUsed = nil
        end

        if isExitOpened(targetExit) then
            log("✅ Exit already open! Going in...")
            escape(targetExit)
            lastExitUsed = targetExit.model
        else
            local otherOpener = getPlayerOpeningDoor(targetExit.trigger)
            if otherOpener then
                log("🤝 Other player opening: " .. otherOpener.Name .. ", waiting alongside...")
                tpFront(targetExit.trigger)
                local opened, beastInterrupted = waitForDoorOpen(targetExit, 20)
                if opened then
                    escape(targetExit)
                    lastExitUsed = targetExit.model
                end
            else
                tpFront(targetExit.trigger)
                log("[EXIT] TP đến cửa exit | trigger=" .. targetExit.trigger.Name .. " pos=" .. tostring(math.floor(targetExit.trigger.Position.X)) .. "," .. tostring(math.floor(targetExit.trigger.Position.Y)) .. "," .. tostring(math.floor(targetExit.trigger.Position.Z)))
                task.wait(0.2)
                local success = startOpening(targetExit.trigger)
                if success then
                    local firing = true
                    local lastLogProg = -1
                    task.spawn(function()
                        while firing do
                            task.wait(0.05) -- FIX Bug1: fire nhanh hơn
                            pcall(function()
                                local root2 = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
                                if root2 then
                                    safeFire(root2, targetExit.trigger, 0)
                                    safeFire(root2, targetExit.trigger, 1)
                                end
                                local r = ReplicatedStorage:FindFirstChild("RemoteEvent")
                                if r then r:FireServer("Input", "Action", true) end
                            end)
                            -- Log ActionProgress mỗi 10%
                            local prog = getActionProgress(player)
                            local pct = math.floor(prog * 10) * 10
                            if pct ~= lastLogProg and pct > 0 then
                                lastLogProg = pct
                                log("🚪 [EXIT] Đang mở cửa: " .. pct .. "%")
                            end
                        end
                    end)
                    local opened, beastInterrupted = waitForDoorOpen(targetExit, 20)
                    firing = false
                    if beastInterrupted then
                        log("👹 [EXIT] Beast vào lúc đang mở cửa! Tìm exit khác...", "warn")
                        -- FIX Bug2: TP cao lên exit khác để tránh bị đánh
                        local safeExit = nil
                        for _, e in ipairs(exits) do
                            if e.model ~= targetExit.model then safeExit = e break end
                        end
                        if safeExit then
                            local _c = player.Character
                            local _r = _c and _c:FindFirstChild("HumanoidRootPart")
                            if _r then
                                _r.CFrame = CFrame.new(_r.Position.X, _r.Position.Y + 35, _r.Position.Z)
                                log("[EXIT] TP lên cao 35 studs để tránh beast")
                            else
                                log("[EXIT] Không tìm được rootPart để TP tránh beast!", "error")
                            end
                        else
                            log("[EXIT] Không có exit thứ 2 để chuyển sang!", "error")
                        end
                        -- Chờ beast đi xa hẳn rồi mới retry
                        local bw = 0
                        while isBeastNearby(45) and scriptEnabled and not hasEscaped and bw < 15 do
                            task.wait(0.3)
                            bw = bw + 0.3
                        end
                        if bw >= 15 then
                            log("[EXIT] Chờ beast 15s vẫn chưa rời → tiếp tục anyway", "warn")
                        else
                            log("[EXIT] Beast đã rời sau " .. string.format("%.1f", bw) .. "s → retry")
                        end
                    elseif opened then
                        escape(targetExit)
                        lastExitUsed = targetExit.model
                    else
                        log("⏱ Door timeout, switching to other exit...")
                    end
                end
            end
        end
    end

end


-- ==================== SELF BEAST CHECK ====================
local function isSelfBeast()
    local stats = player:FindFirstChild("TempPlayerStatsModule")
    if not stats then return false end
    local flag = stats:FindFirstChild("IsBeast")
    return flag and flag.Value == true
end

-- ==================== ALT MODE HELPERS ====================
local function getFollowTarget()
    if followTargetName == "" then return nil end
    return Players:FindFirstChild(followTargetName)
end

local function hasMainEscaped()
    local main = getFollowTarget()
    if not main then return false end
    local stats = main:FindFirstChild("TempPlayerStatsModule")
    if not stats then return false end
    local esc = stats:FindFirstChild("Escaped")
    return esc and esc.Value == true
end

-- Tìm PC mà targetPlayer đang đứng gần (trong vòng 15 studs)
local function getPCNearPlayer(targetPlayer)
    if not targetPlayer or not targetPlayer.Character then return nil end
    local targetRoot = targetPlayer.Character:FindFirstChild("HumanoidRootPart")
    if not targetRoot then return nil end
    local nearest, nearestDist = nil, math.huge
    for _, pcData in ipairs(allPCs) do
        for _, trigger in ipairs(pcData.triggers) do
            local dist = (targetRoot.Position - trigger.Position).Magnitude
            if dist < nearestDist then
                nearest = pcData
                nearestDist = dist
            end
        end
    end
    return (nearestDist < 15) and nearest or nil
end

-- Check xem mình có đang bị nhốt trong cage không
local function isSelfCaged()
    local char = player.Character
    if not char then return false end
    local selfTorso = char:FindFirstChild("UpperTorso") or char:FindFirstChild("Torso")
    if not selfTorso then return false end
    local mapVal = ReplicatedStorage:FindFirstChild("CurrentMap")
    mapVal = mapVal and mapVal.Value
    if not mapVal then return false end
    for _, v in ipairs(mapVal:GetChildren()) do
        if v.Name == "FreezePod" then
            local ct = v:FindFirstChild("CapturedTorso", true)
            if ct and ct.Value == selfTorso then return true end
        end
    end
    return false
end

-- ==================== BEAST AUTO ====================
local function getHammerEvent()
    local char = player.Character
    local hammer = char and char:FindFirstChild("Hammer")
    return hammer and hammer:FindFirstChild("HammerEvent")
end

-- excludeName: nếu có thì bỏ qua player đó (dùng cho alt mode)
local function getBeastNearestSurvivor(excludeName)
    local char = player.Character
    if not char then return nil end
    local root = char:FindFirstChild("HumanoidRootPart")
    if not root then return nil end
    local nearest, nearestDist = nil, math.huge
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= player and p.Character then
            if excludeName and p.Name == excludeName then continue end
            local hum = p.Character:FindFirstChild("Humanoid")
            local torso = p.Character:FindFirstChild("UpperTorso") or p.Character:FindFirstChild("Torso")
            if hum and torso then
                local captured = false
                local map = ReplicatedStorage:FindFirstChild("CurrentMap")
                map = map and map.Value
                if map then
                    for _, v in ipairs(map:GetChildren()) do
                        if v.Name == "FreezePod" then
                            local ct = v:FindFirstChild("CapturedTorso", true)
                            if ct and ct.Value == torso then captured = true break end
                        end
                    end
                end
                if not captured then
                    local dist = (root.Position - torso.Position).Magnitude
                    if dist < nearestDist then nearest = p nearestDist = dist end
                end
            end
        end
    end
    return nearest
end

local function getBeastNearestRagdoll()
    local char = player.Character
    if not char then return nil end
    local root = char:FindFirstChild("HumanoidRootPart")
    if not root then return nil end
    local nearest, nearestDist = nil, math.huge
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= player and p.Character then
            local hum = p.Character:FindFirstChild("Humanoid")
            local torso = p.Character:FindFirstChild("UpperTorso")
                or p.Character:FindFirstChild("Torso")
            if hum and torso and hum.PlatformStand then
                local dist = (root.Position - torso.Position).Magnitude
                if dist < nearestDist then
                    nearest = p
                    nearestDist = dist
                end
            end
        end
    end
    return nearest
end

local function getBeastNearestEmptyCage()
    local char = player.Character
    if not char then return nil end
    local root = char:FindFirstChild("HumanoidRootPart")
    if not root then return nil end
    local map = ReplicatedStorage:FindFirstChild("CurrentMap")
    map = map and map.Value
    if not map then return nil end
    local nearest, nearestDist = nil, math.huge
    for _, v in ipairs(map:GetChildren()) do
        if v.Name == "FreezePod" then
            local ct = v:FindFirstChild("CapturedTorso", true)
            if ct and ct.Value == nil then
                local trigger = v:FindFirstChild("PodTrigger", true)
                if trigger then
                    local dist = (root.Position - trigger.Position).Magnitude
                    if dist < nearestDist then
                        nearest = v
                        nearestDist = dist
                    end
                end
            end
        end
    end
    return nearest
end

local function beastLoop()
    while true do
        task.wait(0.05) -- tăng từ 0.1 -> 0.05
        if not scriptEnabled or not isSelfBeast() then continue end
        if not isGameActive() then
            updateStatus("Beast: waiting for round...")
            task.wait(1)
            continue
        end

        local remote = getHammerEvent()
        if not remote then continue end

        local char = player.Character
        if not char then continue end
        local root = char:FindFirstChild("HumanoidRootPart")
        if not root then continue end

        -- ===== ƯU TIÊN 1: Đang có rope -> cage NGAY =====
        local ropeCheck = char:FindFirstChild("RopeConstraint", true)
        if ropeCheck then
            local cage = getBeastNearestEmptyCage()
            if not cage then continue end
            local trigger = cage:FindFirstChild("PodTrigger", true)
            if not trigger then continue end

            updateStatus("Beast: Caging...")
            local cageCenter = cage:GetModelCFrame().Position
            local dirIn = (cageCenter - trigger.Position)
            if dirIn.Magnitude > 0 then dirIn = dirIn.Unit * 2 else dirIn = Vector3.zero end
            local cagePos = Vector3.new(trigger.Position.X + dirIn.X, trigger.Position.Y, trigger.Position.Z + dirIn.Z)

            local hum = char:FindFirstChild("Humanoid")
            if hum then hum.PlatformStand = true hum:ChangeState(Enum.HumanoidStateType.Physics) end

            -- Noclip + pin position
            local noclipActive = true
            local noclipConn = RunService.Stepped:Connect(function()
                if not noclipActive then return end
                local c = player.Character
                if not c then return end
                for _, p in pairs(c:GetDescendants()) do
                    if p:IsA("BasePart") then p.CanCollide = false end
                end
            end)
            local freezeActive = true
            local freezeConn = RunService.Heartbeat:Connect(function()
                if not freezeActive then return end
                root.CFrame = CFrame.new(cagePos)
                root.AssemblyLinearVelocity = Vector3.zero
                root.AssemblyAngularVelocity = Vector3.zero
            end)

            root.CFrame = CFrame.new(cagePos)
            root.AssemblyLinearVelocity = Vector3.zero

            -- Spam interact nhanh hơn: 0.05s thay vì 0.15s
            local t = 0
            while t < 2.5 do
                pcall(function()
                    safeFire(root, trigger, 0)
                    safeFire(root, trigger, 1)
                    local r = ReplicatedStorage:FindFirstChild("RemoteEvent")
                    if r then r:FireServer("Input", "Action", true) end
                end)
                local ct = cage:FindFirstChild("CapturedTorso", true)
                if ct and ct.Value ~= nil then break end
                task.wait(0.05)
                t = t + 0.05
            end

            freezeActive = false; freezeConn:Disconnect()
            noclipActive = false; noclipConn:Disconnect()
            if hum then hum.PlatformStand = false hum:ChangeState(Enum.HumanoidStateType.GettingUp) end
            continue
        end

        -- ===== ƯU TIÊN 2: Có ragdoll -> rope NGAY =====
        local ragdollTarget = getBeastNearestRagdoll()
        if ragdollTarget and ragdollTarget.Character then
            local torso = ragdollTarget.Character:FindFirstChild("UpperTorso") or ragdollTarget.Character:FindFirstChild("Torso")
            if torso then
                updateStatus("Beast: Roping " .. ragdollTarget.Name)
                -- TP sát vào target
                root.CFrame = CFrame.new(torso.Position + Vector3.new(0, 0, 1))
                -- Spam rope không delay
                local ropeTimer = 0
                while ropeTimer < 1.5 do
                    remote:FireServer("HammerTieUp", torso, torso.Position)
                    if char:FindFirstChild("RopeConstraint", true) then break end
                    task.wait(0.05) -- nhanh hơn: 0.05 thay vì 0.15
                    ropeTimer = ropeTimer + 0.05
                end
                continue
            end
        end

        -- ===== ƯU TIÊN 3: Tìm survivor -> TP sát + spam hit =====
        local target
        if playerMode == "alt" then
            local elapsed = tick() - altRoundStartTick
            if elapsed < altCageDelay then
                updateStatus("Beast ALT: Waiting " .. math.ceil(altCageDelay - elapsed) .. "s...")
                task.wait(0.5)
                continue
            end
            target = hasMainEscaped() and getBeastNearestSurvivor() or getBeastNearestSurvivor(followTargetName)
        else
            target = getBeastNearestSurvivor()
        end

        if not target or not target.Character then
            updateStatus("Beast: All captured!")
            task.wait(0.5)
            continue
        end

        local torso = target.Character:FindFirstChild("UpperTorso") or target.Character:FindFirstChild("Torso")
        if not torso then continue end
        local hum = target.Character:FindFirstChild("Humanoid")
        if hum and hum.PlatformStand then continue end

        updateStatus("Beast: Hitting " .. target.Name)

        -- TP sát target
        root.CFrame = CFrame.new(torso.Position + Vector3.new(0, 0, 0.5))

        -- Spam hit nhanh nhất có thể
        local hitTimer = 0
        while hitTimer < 1.5 do
            if not target.Character then break end
            local h = target.Character:FindFirstChild("Humanoid")
            -- Break ngay nếu target bị cage (PlatformStand hoặc Health = 0)
            if h and (h.PlatformStand or h.Health <= 0) then
                log("👹 " .. target.Name .. " caged! Moving on...")
                break
            end
            -- TP liên tục bám theo target
            local t2 = target.Character:FindFirstChild("UpperTorso") or target.Character:FindFirstChild("Torso")
            if t2 then root.CFrame = CFrame.new(t2.Position + Vector3.new(0, 0, 0.5)) end
            remote:FireServer("HammerClick", true)
            remote:FireServer("HammerHit", torso)
            task.wait(0.05)
            hitTimer = hitTimer + 0.05
        end
    end
end

-- ==================== AUTO SAVE (SURVIVOR) ====================
local savesThisRound = 0
local maxSaves = 1
local isMoving = false -- lock: chỉ 1 action move tại 1 thời điểm

local function autoSaveLoop()
    while true do
        task.wait(0.3)
        if not scriptEnabled or isSelfBeast() then continue end
        if savesThisRound >= maxSaves then continue end
        if isMoving then continue end
        if roundsPlayed == 0 or not isGameActive() then continue end

        -- Tìm survivor bị nhốt trong cage
        local map = ReplicatedStorage:FindFirstChild("CurrentMap")
        map = map and map.Value
        if not map then continue end

        local root = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
        if not root then continue end

        for _, v in ipairs(map:GetChildren()) do
            if v.Name == "FreezePod" then
                local ct = v:FindFirstChild("CapturedTorso", true)
                local trigger = v:FindFirstChild("PodTrigger", true)
                if ct and ct.Value ~= nil and trigger then
                    -- Có người bị nhốt -> tp tới save
                    local capturedPlayer = nil
                    for _, p in ipairs(Players:GetPlayers()) do
                        if p ~= player and p.Character then
                            local torso = p.Character:FindFirstChild("UpperTorso") or p.Character:FindFirstChild("Torso")
                            if torso and ct.Value == torso then
                                capturedPlayer = p break
                            end
                        end
                    end
                    if capturedPlayer then
                        isSaving = true
                        isMoving = true
                        isReturning = true -- tắt beast check từ lúc này
                        local savedCanJump = canAutoJump
                        canAutoJump = false
                        log("🚑 [SAVE] Phát hiện " .. capturedPlayer.Name .. " bị nhốt! Bắt đầu save #" .. (savesThisRound+1))
                        updateStatus("Saving: " .. capturedPlayer.Name)
                        local cageCenter = v:GetModelCFrame().Position
                        local dirIn = (cageCenter - trigger.Position)
                        if dirIn.Magnitude > 0 then dirIn = dirIn.Unit * 3 else dirIn = Vector3.zero end
                        local savePos = Vector3.new(trigger.Position.X + dirIn.X, trigger.Position.Y, trigger.Position.Z + dirIn.Z)
                        -- Lưu trạng thái trước khi save
                        local wasHacking = isHacking -- true = đang hack, false = đang tween
                        local returnTrigger = currentTrigger
                        local returnPC = currentPC
                        if not returnTrigger and returnPC and returnPC.triggers and #returnPC.triggers > 0 then
                            returnTrigger = returnPC.triggers[1]
                            log("🚑 Save during tween, will return to PC" .. tostring(returnPC.id) .. " trigger 1")
                        end

                        -- Noclip trước khi TP vào cage
                        local char = player.Character
                        local hum = char and char:FindFirstChild("Humanoid")
                        if hum then
                            hum.PlatformStand = true
                            hum:ChangeState(Enum.HumanoidStateType.Physics)
                        end
                        local noclipActive = true
                        local noclipConn = RunService.Stepped:Connect(function()
                            if not noclipActive then return end
                            local c = player.Character
                            if not c then return end
                            for _, part in pairs(c:GetDescendants()) do
                                if part:IsA("BasePart") then part.CanCollide = false end
                            end
                        end)

                        -- TP thẳng tới cage + freeze để không bị đẩy ra
                        root.CFrame = CFrame.new(savePos)
                        root.AssemblyLinearVelocity = Vector3.zero
                        root.AssemblyAngularVelocity = Vector3.zero
                        task.wait(0.15)

                        -- Heartbeat pin position để chống gravity
                        local freezeActive = true
                        local freezeConn = RunService.Heartbeat:Connect(function()
                            if not freezeActive then return end
                            pcall(function()
                                root.CFrame = CFrame.new(savePos)
                                root.AssemblyLinearVelocity = Vector3.zero
                                root.AssemblyAngularVelocity = Vector3.zero
                            end)
                        end)

                        -- Interact save
                        local t = 0
                        while t < 3 do
                            pcall(function() safeFire(root, trigger, 0) task.wait(0.03) safeFire(root, trigger, 1) end)
                            pcall(function() local r = ReplicatedStorage:FindFirstChild("RemoteEvent") if r then r:FireServer("Input", "Action", true) end end)
                            ct = v:FindFirstChild("CapturedTorso", true)
                            if ct and ct.Value == nil then
                                savesThisRound = savesThisRound + 1
                                log("✅ [SAVE] Đã giải cứu " .. capturedPlayer.Name .. "! Tổng saves ván này=" .. (savesThisRound+1))
                                updateStatus("Saved! Returning to PC...")
                                break
                            end
                            task.wait(0.15)
                            t = t + 0.18
                        end

                        freezeActive = false
                        freezeConn:Disconnect()

                        -- Tắt noclip + unfreeze
                        noclipActive = false
                        noclipConn:Disconnect()
                        if hum then
                            hum.PlatformStand = false
                            hum:ChangeState(Enum.HumanoidStateType.GettingUp)
                        end

                        -- Reset state
                        canAutoJump = savedCanJump
                        isSaving = false
                        isMoving = false
                        isHacking = false
                        currentTrigger = nil
                        skippedPCs = {}
                        allPCs = findAllPCs()

                        if not isGameActive() or gameOver then break end

                        if returnPC then
                            currentPC = returnPC
                            isHacking = true
                            if wasHacking then
                                log("🔄 Was hacking → TP back to PC" .. tostring(returnPC.id) .. "...")
                                updateStatus("🔄 TP back to PC " .. tostring(returnPC.id) .. "...")
                                task.spawn(function()
                                    if isGameActive() and not gameOver then
                                        hackPC(returnPC)
                                    end
                                    isReturning = false
                                    isHacking = false
                                end)
                            else
                                log("🔄 Was tweening → tween back to PC" .. tostring(returnPC.id) .. "...")
                                updateStatus("🔄 Returning to PC " .. tostring(returnPC.id) .. "...")
                                firstMoveOfRound = false
                                task.spawn(function()
                                    if isGameActive() and not gameOver then
                                        hackPC(returnPC)
                                    end
                                    isReturning = false
                                    isHacking = false
                                end)
                            end
                        else
                            isReturning = false -- không có PC để về thì bật lại luôn
                        end
                    end
                end
            end
        end
    end
end

-- ==================== MAIN LOOP ====================
local function mainLoop()

    while true do
        if not scriptEnabled then
            isHacking = false
            currentPC = nil
            canAutoJump = false
            hasEscaped = false
            task.wait(0.5)
            continue
        end

        if not waitForGameActive() then
            log("waitForGameActive failed, retry in 10s")
            task.wait(10)
            continue
        end

        roundsPlayed = roundsPlayed + 1
        resetGameState()
        altRoundStartTick = tick()
        savesThisRound = 0
        firstMoveOfRound = true

        -- Auto-clear console mỗi 50 rounds để tránh memory buildup
        if roundsPlayed % 50 == 0 then
            logBuffer = {}
            if consoleLogFn then
                pcall(function()
                    local player2 = game.Players.LocalPlayer
                    local gui = player2:FindFirstChild("PlayerGui")
                    if gui then
                        local ag = gui:FindFirstChild("AutoHackGUI")
                        if ag then
                            local scroll = ag:FindFirstChild("ConsoleScroll", true)
                            if scroll then
                                for _, c in ipairs(scroll:GetChildren()) do
                                    if c:IsA("TextLabel") then c:Destroy() end
                                end
                                scroll.CanvasSize = UDim2.new(0,0,0,0)
                                log("🧹 Console cleared (round " .. roundsPlayed .. ")")
                            end
                        end
                    end
                end)
            end
        end

        log("=== [ROUND " .. roundsPlayed .. " BẮT ĐẦU] HackExtra=" .. tostring(hackExtraPC) .. " | Mode=" .. playerMode .. " | PCs=" .. #allPCs .. " | GameStatus=" .. tostring(ReplicatedStorage:FindFirstChild("GameStatus") and ReplicatedStorage:FindFirstChild("GameStatus").Value or "?") .. " ===")

        -- Nếu là beast thì skip toàn bộ sur logic
        if isSelfBeast() then
            updateStatus("Beast mode - auto running")
            repeat task.wait(1) until not scriptEnabled or not isSelfBeast()
            continue
        end

        -- ==================== ALT SURVIVOR MODE ====================
        if playerMode == "alt" then
            local main = getFollowTarget()
            if not main then
                updateStatus("ALT: No main player selected!")
                -- Chờ cho đến khi có follow target
                repeat task.wait(0.5) until followTargetName ~= "" or not scriptEnabled
                if not scriptEnabled then continue end
                main = getFollowTarget()
                if not main then task.wait(2) continue end
            end

            updateStatus("ALT: Following " .. main.Name)
            altWasRescued = false
            allPCs = findAllPCs()

            -- ALT survivor loop
            while scriptEnabled and not gameOver do
                task.wait(0.2)

                if not isGameActive() then break end

                -- Reload main ref
                main = getFollowTarget()
                if not main then
                    updateStatus("ALT: Mất main player!")
                    break
                end

                -- Check nếu đang bị nhốt trong cage
                if isSelfCaged() then
                    log("🔒 [ALT] Bị nhốt vào cage! Chờ " .. main.Name .. " đến cứu...", "warn")
                    updateStatus("ALT: Caged! Waiting for " .. main.Name .. " to rescue...")
                    altWasRescued = false
                    -- Đợi cho đến khi được thả
                    while isSelfCaged() and scriptEnabled and isGameActive() do
                        task.wait(0.3)
                    end
                    if not isSelfCaged() then
                        altWasRescued = true
                        log("ALT: Vừa được cứu khỏi cage!")
                    end
                end

                -- Vừa được cứu -> TP về main ngay
                if altWasRescued then
                    altWasRescued = false
                    local mainChar = main.Character
                    local mainRoot = mainChar and mainChar:FindFirstChild("HumanoidRootPart")
                    if mainRoot and rootPart then
                        updateStatus("ALT: Rescued! Returning to " .. main.Name .. "...")
                        rootPart.CFrame = mainRoot.CFrame + Vector3.new(2, 0, 0)
                    end
                    task.wait(0.5)
                end

                -- Giai đoạn Find Exit -> tự exit
                if isFindExitPhase() then
                    updateStatus("ALT: Find Exit! Auto-escaping...")
                    autoExitUnified()
                    break
                end

                -- Tìm PC main đang hack và vào hack cùng
                local mainPC = getPCNearPlayer(main)
                if mainPC and not hackedPCs[mainPC.id] then
                    log("[ALT] Co-hack cùng main tại PC" .. mainPC.id)
                    updateStatus("ALT: Co-hacking with main at PC " .. mainPC.id)
                    hackPC(mainPC)
                else
                    -- Main không ở gần PC nào hoặc PC đã done -> follow vị trí main
                    local mainChar = main.Character
                    local mainRoot = mainChar and mainChar:FindFirstChild("HumanoidRootPart")
                    if mainRoot and rootPart then
                        local dist = (rootPart.Position - mainRoot.Position).Magnitude
                        if dist > 18 then
                            updateStatus("ALT: Following " .. main.Name .. "...")
                            rootPart.CFrame = mainRoot.CFrame + Vector3.new(2, 0, 0)
                        else
                            updateStatus("ALT: Waiting for " .. main.Name .. " to move...")
                        end
                    end
                end
            end

            -- Chờ round kết thúc hẳn
            repeat task.wait(1) until not isGameActive() or not scriptEnabled
            continue
        end
        -- ==================== END ALT SURVIVOR MODE ====================

        allPCs = findAllPCs()

        if #allPCs == 0 then
            updateStatus("No PCs found")
            task.wait(3)
            continue
        end

        updateStatus("Found " .. #allPCs .. " PC(s)")

        local totalAttempts = 0
        local roundStartTick = tick()

        while scriptEnabled and not (isFindExitPhase() and not hackExtraPC) do
            -- Safety: thoát sau 5 phút nếu bị kẹt
            if tick() - roundStartTick > 300 then
                log("⚠ Round timeout 5min, moving on...")
                break
            end
            -- Nếu đang return về PC sau save thì chờ
            if isReturning or isSaving then
                while (isReturning or isSaving) and isGameActive() and scriptEnabled do
                    task.wait(0.2)
                end
            end

            -- Check game còn active không trước mỗi vòng
            local gs2 = ReplicatedStorage:FindFirstChild("GameStatus")
            local gs2txt = gs2 and tostring(gs2.Value):upper() or ""
            if not isGameActive() and not isFindExitPhase() then
                log("Game ended, stop hacking | status='" .. gs2txt .. "'")
                break
            end

            local hasSkippedPC = false
            local allCompleted = true

            for idx, pcData in ipairs(allPCs) do
                if not scriptEnabled then break end

                -- Check game còn active không
                local gsCheck = ReplicatedStorage:FindFirstChild("GameStatus")
                local gsCheckTxt = gsCheck and tostring(gsCheck.Value):upper() or ""
                if not isGameActive() then
                    allCompleted = true
                    break
                end

                if isBeastNearby(23) and not isReturning and not isSaving then
                    escapeBeast()
                    skipCurrentPC = true
                    local _bDist2 = 0
                    pcall(function() local br2 = beast and beast.Character and (beast.Character:FindFirstChild("HumanoidRootPart") or beast.Character:FindFirstChild("Torso")) if br2 and rootPart then _bDist2 = math.floor((rootPart.Position - br2.Position).Magnitude) end end)
                    log("👹 [MAIN] Beast cách " .. _bDist2 .. " studs khi đang ở PC" .. tostring(currentPC and currentPC.id or "?") .. " → dừng hack chờ beast rời", "warn")
                    updateStatus("👹 Beast nearby, waiting to leave... (PC" .. tostring(currentPC and currentPC.id or "?") .. ")")
                    local beastLeft = false
                    local gameEndedDuringWait = false
                    while scriptEnabled do
                        if isSaving then
                            while isSaving do task.wait(0.2) end
                            skippedPCs = {}
                        end
                        if not isGameActive() or gameOver then
                            gameEndedDuringWait = true
                            break
                        end
                        -- FIX hackExtraPC: nếu hackExtra thì không bỏ qua dù Find Exit đã bắt đầu
                        if isFindExitPhase() and not hackExtraPC then break end
                        if not isBeastNearby(30) then
                            beastLeft = true
                            break
                        end
                        task.wait(0.5)
                    end
                    if beastLeft then
                        skippedPCs = {}
                    end
                    if gameEndedDuringWait then
                        allCompleted = true
                        break
                    end
                    allCompleted = false
                    hasSkippedPC = true -- PC bị skip do beast, cần retry
                    break -- restart for loop từ đầu
                else
                    skipCurrentPC = false
                end

                if isFindExitPhase() and not hackExtraPC then
                    log("🚪 Find Exit phase detected! Stop hacking PCs")
                    allCompleted = true
                    break
                end

                local pcId = pcData.id

                if hackedPCs[pcId] then
                    -- silent skip
                elseif skippedPCs[pcId] then
                    hasSkippedPC = true
                else
                    -- Nếu autoSaveLoop đang xử lý hackPC thì chờ
                    if isSaving or isHacking then
                        while (isSaving or isHacking) and isGameActive() and scriptEnabled do
                            task.wait(0.2)
                        end
                    end
                    local progress = getPCProgress(pcData)
                    if progress >= 1 then
                        hackedPCs[pcId] = true
                    else
                        allCompleted = false
                        hackPC(pcData)
                    end
                end
            end
            totalAttempts = totalAttempts + 1

            if allCompleted then
                log("✅ [MAIN] Tất cả PC đã hack xong! Tổng=" .. #allPCs .. " | Chờ Find Exit phase...")
                break
            end

            if hasSkippedPC then
                local remainingCount = 0
                for id, _ in pairs(skippedPCs) do
                    if not hackedPCs[id] then remainingCount += 1 end
                end
                if remainingCount > 0 then
                    updateStatus("Skipped " .. remainingCount .. " PC(s), waiting beast to leave...")
                    local beastGone = false
                    -- Chạy trốn beast ngay
                    if isBeastNearby(35) then
                        escapeBeast()
                    end
                    while scriptEnabled and isGameActive() and not gameOver do
                        if not isBeastNearby(35) then
                            skippedPCs = {}
                            log("👹 Beast left! Retrying skipped PCs...")
                            beastGone = true
                            break
                        end
                        if isFindExitPhase() and not hackExtraPC then break end
                        task.wait(0.5)
                    end
                    if beastGone then
                        totalAttempts = 0
                    end
                else
                    break
                end
            end
        end

        -- FIX hackExtraPC: nếu còn PC bị skip chưa hack thì retry trước khi exit
        if hackExtraPC then
            local hasUnhacked = false
            for _, pcData in ipairs(allPCs) do
                if not hackedPCs[pcData.id] then
                    hasUnhacked = true
                    break
                end
            end
            if hasUnhacked and isGameActive() then
                log("⚡ [EXTRA] Còn PC chưa hack (bị skip do beast) → retry trước khi exit", "warn")
                skippedPCs = {}
                continue -- quay lại vòng while để hack nốt
            end
            task.wait(2)
        end

        -- Nếu đang save thì chờ save xong rồi mới tiếp
        if isSaving then
            log("⏳ Waiting for save to finish before Find Exit check...")
            while isSaving do task.wait(0.2) end
            -- Sau save xong, nếu game vẫn active thì quay lại hack tiếp
            if isGameActive() and not isFindExitPhase() then
                log("🔄 Save done, resuming hack loop...")
                continue
            end
        end

        -- Tắt hacking state trước khi wait
        isHacking = false
        canAutoJump = false
        currentTrigger = nil
        currentPC = nil

        -- Wait for Find Exit
        log("⏳ Waiting for Find Exit phase...")
        updateStatus("Waiting for Find Exit...")
        local waitStart = tick()
        repeat
            task.wait(0.3)
        until isFindExitPhase()
            or not isGameActive()
            or (tick() - waitStart > 60)
            or not scriptEnabled

        if not scriptEnabled then continue end

        if isFindExitPhase() then
            log("🚪 [MAIN] Find Exit phase phát hiện! Bắt đầu auto-exit...")
            updateStatus("Auto Exit started!")
            autoExitUnified()
            log("=== ROUND " .. roundsPlayed .. " COMPLETE ===")
        else
            log("⏱ Find Exit timeout or game ended, waiting for new round...")
        end

        -- Chờ về sảnh hoàn toàn trước khi bắt đầu round mới
        updateStatus("Waiting for lobby...")
        local waitEnd = tick()
        repeat
            task.wait(0.5)
        until isInLobby() or (tick() - waitEnd > 60) or not scriptEnabled
        task.wait(2)
    end
end

