    -- Track touch/mouse position - chỉ theo dõi 1 ngón tay (touch ID đầu tiên)
    local activeTouchId = nil -- lock vào 1 touch duy nhất

    local function isMine(i)
        if i.UserInputType == Enum.UserInputType.MouseButton1
        or i.UserInputType == Enum.UserInputType.MouseMovement then
            return true
        end
        if i.UserInputType == Enum.UserInputType.Touch then
            return activeTouchId == nil or activeTouchId == i
        end
        return false
    end

    UIS.InputChanged:Connect(function(i)
        if not isMine(i) then return end
        if i.UserInputType == Enum.UserInputType.MouseMovement
        or i.UserInputType == Enum.UserInputType.Touch then
            touchPos = Vector2.new(i.Position.X, i.Position.Y)
        end
    end)

    UIS.InputEnded:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.MouseButton1
        or (i.UserInputType == Enum.UserInputType.Touch and i == activeTouchId) then
            speedDrag=false; cageDrag=false; intervalDrag=false
            dragging=false; conDragging=false
            activeTouchId = nil
        end
    end)

    local function beginDrag(i)
        -- Chỉ nhận ngón tay đầu tiên, bỏ qua ngón sau
        if i.UserInputType == Enum.UserInputType.Touch then
            if activeTouchId ~= nil then return false end
            activeTouchId = i
        elseif i.UserInputType ~= Enum.UserInputType.MouseButton1 then
            return false
        end
        touchPos = Vector2.new(i.Position.X, i.Position.Y)
        return true
    end

