local function waitForGameActive()
    local gs  = ReplicatedStorage:FindFirstChild("GameStatus")
    local txt = gs and tostring(gs.Value):upper() or ""
    local map = ReplicatedStorage:FindFirstChild("CurrentMap")
    local mapName = map and map.Value and map.Value.Name or "nil"
    log("waitForGame: lobby=" .. tostring(isInLobby()) .. " map='" .. mapName .. "'")

    if isInGame() and (txt:find("GAME OVER") or txt:find("BEAST LEFT") or txt:find("INTERMISSION")) then
        log("waitForGame: game over in map, waiting for lobby...")
        repeat task.wait(0.5) until isInLobby() or not scriptEnabled
    end

    if isInGame() then
        log("waitForGame: already in-game!")
        return true
    end

    updateStatus("Waiting for game...")
    local timeout = 300; local elapsed = 0; local lastLog = -1
    local myTok = scriptToken
    while elapsed < timeout do
        task.wait(0.5); elapsed += 0.5
        if not scriptEnabled or scriptToken ~= myTok then return false end
        if isInGame() then
            log("waitForGame: TP'd into map!")
            task.wait(1); return true
        end
        local s = math.floor(elapsed)
        if s % 15 == 0 and elapsed > 0 and s ~= lastLog then
            lastLog = s
            local mv = ReplicatedStorage:FindFirstChild("CurrentMap")
            log("waitForGame: still waiting... (" .. s .. "s)")
        end
    end
    log("waitForGame: timeout!")
    return false
end

-- ============================================================
-- MAIN LOOP
-- ============================================================
local function mainLoop()
    while true do
        -- Script OFF: cleanup 1 lần, chờ bật lại
        if not scriptEnabled then
            isHacking = false; currentPC = nil; canAutoJump = false
            hasEscaped = false; isMoving = false
            pcall(function()
                workspace.Gravity = 196.2
                local root = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
                if root then
                    root.AssemblyLinearVelocity = Vector3.zero
                    root.AssemblyAngularVelocity = Vector3.zero
                end
                local hum = player.Character and player.Character:FindFirstChild("Humanoid")
                if hum then
                    if not isSelfBeast() then
                    end
                    hum.PlatformStand = false
                    hum:ChangeState(Enum.HumanoidStateType.GettingUp)
                end
            end)
            updateStatus("Script OFF")
            setState("off")
            repeat task.wait(0.2) until scriptEnabled
            continue
        end

        if not waitForGameActive() then
            log("waitForGameActive failed, retry in 10s")
            task.wait(10); continue
        end

        roundsPlayed += 1
        resetGameState()
        altRoundStartTick = tick()

        -- Auto-clear console mỗi 50 rounds
        if roundsPlayed % 50 == 0 then
            logBuffer = {}
            pcall(function()
                if consoleLogFn then
                    local pg = player:FindFirstChild("PlayerGui")
                    local gui = pg and pg:FindFirstChild("AutoHackGUI")
                    -- consoleLogFn sẽ tự rebuild trong GUI
                end
            end)
        end

        log("=== [ROUND " .. roundsPlayed .. " START] HackExtra=" .. tostring(hackExtraPC) .. " Mode=" .. playerMode .. " ===")

        -- Nếu là beast thì skip survivor logic
        if isSelfBeast() then
            setState("beast")
            updateStatus("Beast mode - auto running")
            repeat task.wait(1) until not scriptEnabled or not isSelfBeast()
            continue
        end

        -- ==================== ALT SURVIVOR MODE ====================
        if playerMode == "alt" then
            local main = Players:FindFirstChild(followTargetName)
            if not main then
                updateStatus("ALT: No main player selected!")
                repeat task.wait(0.5) until followTargetName ~= "" or not scriptEnabled
                if not scriptEnabled then continue end
                main = Players:FindFirstChild(followTargetName)
                if not main then task.wait(2) continue end
            end

            updateStatus("ALT: Following " .. main.Name)
            altWasRescued = false
            allPCs = findAllPCs()

            local altTok = scriptToken
            while scriptEnabled and scriptToken == altTok and not gameOver do
                task.wait(0.2)
                if not isGameActive() then break end
                main = Players:FindFirstChild(followTargetName)
                if not main then updateStatus("ALT: Mất main!"); break end

                -- Check bị cage
                if isSelfCaged() then
                    log("🔒 [ALT] Bị nhốt! Chờ " .. main.Name .. " cứu...")
                    updateStatus("ALT: Caged! Waiting for " .. main.Name .. "...")
                    altWasRescued = false
                    while isSelfCaged() and scriptEnabled and isGameActive() do task.wait(0.3) end
                    if not isSelfCaged() then altWasRescued = true; log("ALT: Vừa được cứu!") end
                end

                -- Vừa được cứu → TP về main
                if altWasRescued then
                    altWasRescued = false
                    local mainRoot = main.Character and main.Character:FindFirstChild("HumanoidRootPart")
                    if mainRoot and rootPart then
                        updateStatus("ALT: Rescued! Returning to " .. main.Name .. "...")
                        rootPart.CFrame = mainRoot.CFrame + Vector3.new(2, 0, 0)
                    end
                    task.wait(0.5)
                end

                if isFindExitPhase() then
                    updateStatus("ALT: Find Exit! Auto-escaping...")
                    autoExitUnified(); break
                end

                -- Co-hack cùng main
                local mainPC = getPCNearPlayer(main)
                if mainPC and not hackedPCs[mainPC.id] then
                    log("[ALT] Co-hack cùng main tại PC" .. mainPC.id)
                    updateStatus("ALT: Co-hacking with main at PC " .. mainPC.id)
                    hackPC(mainPC, altTok, false)
                else
                    local mainRoot = main.Character and main.Character:FindFirstChild("HumanoidRootPart")
                    if mainRoot and rootPart then
                        local dist = (rootPart.Position - mainRoot.Position).Magnitude
                        if dist > 18 then
                            updateStatus("ALT: Following " .. main.Name .. "...")
                            rootPart.CFrame = mainRoot.CFrame + Vector3.new(2, 0, 0)
                        else
                            updateStatus("ALT: Waiting for " .. main.Name .. "...")
                        end
                    end
                end
            end

            repeat task.wait(1) until not isGameActive() or not scriptEnabled
            continue
        end
        -- ==================== END ALT MODE ====================

        -- ==================== MAIN SURVIVOR MODE ====================
        allPCs = findAllPCs()
        if #allPCs == 0 then
            updateStatus("No PCs found"); task.wait(3); continue
        end
        updateStatus("Found " .. #allPCs .. " PC(s)")

        local roundStartTick = tick()
        local myTok = scriptToken
        firstMoveOfRound = true

        while scriptEnabled and scriptToken == myTok do
            -- Safety timeout 5 phút
            if tick() - roundStartTick > 300 then log("⚠ Round timeout 5min"); break end

            -- Chờ nếu đang save/return
            if isReturning or isSaving then
                while (isReturning or isSaving) and isGameActive() and scriptEnabled do task.wait(0.2) end
            end

            -- Check game state
            if not isGameActive() and not isFindExitPhase() then
                log("Game ended"); break
            end
            if isFindExitPhase() and not hackExtraPC then break end

            local hasSkippedPC = false
            local allCompleted = true

            for _, pcData in ipairs(allPCs) do
                if not scriptEnabled or scriptToken ~= myTok then break end
                if isFindExitPhase() and not hackExtraPC then allCompleted = true; break end
                if not isGameActive() then allCompleted = true; break end

                -- Beast check trước khi tween
                if beastNearby and not isReturning and not isSaving then
                    local _bDist = 0
                    pcall(function()
                        local br = beast and beast.Character and (beast.Character:FindFirstChild("HumanoidRootPart") or beast.Character:FindFirstChild("Torso"))
                        if br and rootPart then _bDist = math.floor((rootPart.Position - br.Position).Magnitude) end
                    end)
                    log("👹 [MAIN] Beast cách " .. _bDist .. " studs → skip PC" .. pcData.id .. " tween PC khác ngay")
                    if pcData and pcData.id then skippedPCs[pcData.id] = true end
                    isHacking = false; canAutoJump = false; currentPC = nil; currentTrigger = nil; isMoving = false
                    task.wait(0.5)
                    allCompleted = false; hasSkippedPC = true; break
                end

                local pcId = pcData.id
                if hackedPCs[pcId] then
                    -- Done, silent skip
                elseif skippedPCs[pcId] then
                    hasSkippedPC = true; allCompleted = false
                else
                    -- Chờ nếu save/hack đang chạy
                    if isSaving or isHacking then
                        while (isSaving or isHacking) and isGameActive() and scriptEnabled do task.wait(0.2) end
                    end
                    if getPCProgress(pcData) >= 1 then
                        hackedPCs[pcId] = true
                    else
                        allCompleted = false
                        if isFindExitPhase() and not hackExtraPC then allCompleted = true; break end
                        if isFindExitPhase() and not hackExtraPC then allCompleted = true; break end
                        local isFirst = firstMoveOfRound
                        firstMoveOfRound = false  -- set false trước để lần retry không TP
                        hackPC(pcData, myTok, isFirst)
                        if isFindExitPhase() and not hackExtraPC then
                            log("🚪 Exit phase sau hack PC" .. pcId)
                            allCompleted = true; break
                        end
                    end
                end
            end

            if allCompleted then break end

            if hasSkippedPC then
                local remainingCount = 0
                for id in pairs(skippedPCs) do
                    if not hackedPCs[id] then remainingCount += 1 end
                end
                if remainingCount > 0 then
                    local freeCount = 0
                    for _, pc in ipairs(allPCs) do
                        if not hackedPCs[pc.id] and not skippedPCs[pc.id] then freeCount += 1 end
                    end
                    if freeCount > 0 then
                        if isFindExitPhase() and not hackExtraPC then break end
                        log("👹 Còn " .. freeCount .. " PC free → tween")
                        updateStatus("Beast nearby! Trying other PC...")
                        for _, nextPC in ipairs(allPCs) do
                            if not hackedPCs[nextPC.id] and not skippedPCs[nextPC.id] then
                                allCompleted = false
                                hackPC(nextPC, myTok, false)
                                if isFindExitPhase() and not hackExtraPC then allCompleted = true end
                                break
                            end
                        end
                    else
                        if hackExtraPC then
                            log("👹 hackExtra: beast canh PC extra → exit"); break
                        else
                            log("👹 Tất cả PC bị skip → reset 0.2s rồi hack tiếp")
                            updateStatus("All PCs blocked! Resetting...")
                            task.wait(0.2)
                            skippedPCs = {}
                            log("👹 Reset skip → retry ngay")
                        end
                    end
                else
                    break
                end
            end
        end

        -- hackExtraPC retry
        if hackExtraPC then
            local hasUnhacked = false
            for _, pc in ipairs(allPCs) do
                if not hackedPCs[pc.id] then hasUnhacked = true break end
            end
            if hasUnhacked and isGameActive() and not isFindExitPhase() then
                log("⚡ [EXTRA] Còn PC chưa hack → retry")
                skippedPCs = {}
                task.wait(2)
                continue
            end
        end

        -- Chờ nếu đang save
        if isSaving then
            log("⏳ Chờ save xong...")
            while isSaving do task.wait(0.2) end
            if isGameActive() and not isFindExitPhase() then
                log("🔄 Save done, resume hack..."); continue
            end
        end

        -- Stop hacking state
        isHacking = false; canAutoJump = false; currentTrigger = nil; currentPC = nil

        -- Wait for Find Exit
        log("⏳ Waiting for Find Exit...")
        updateStatus("Waiting for Find Exit...")
        local waitStart = tick()
        repeat task.wait(0.3)
        until isFindExitPhase() or not isGameActive()
            or (tick() - waitStart > 60) or not scriptEnabled

        if not scriptEnabled then continue end

        if isFindExitPhase() then
            log("🚪 Find Exit! Auto-exit...")
            updateStatus("Auto Exit started!")
            autoExitUnified()
            log("=== ROUND " .. roundsPlayed .. " COMPLETE ===")
        else
            log("⏱ Find Exit timeout hoặc game ended")
        end

        -- Chờ về lobby
        updateStatus("Waiting for lobby...")
        local waitEnd = tick()
        repeat task.wait(0.5)
        until isInLobby() or (tick() - waitEnd > 60) or not scriptEnabled
        task.wait(2)
    end
end

