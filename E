    pingIdInput.PlaceholderText = "Enter Discord User ID to ping..."
    pingIdInput.PlaceholderColor3 = Color3.fromRGB(90, 90, 110)
    pingIdInput.TextColor3 = Color3.fromRGB(140, 220, 255)
    pingIdInput.TextSize = 10
    pingIdInput.Font = Enum.Font.Gotham
    pingIdInput.ClearTextOnFocus = false
    pingIdInput.LayoutOrder = 24
    pingIdInput.Visible = false
    Instance.new("UICorner", pingIdInput).CornerRadius = UDim.new(0, 5)
    local pingIdPad = Instance.new("UIPadding", pingIdInput)
    pingIdPad.PaddingLeft = UDim.new(0, 6)
    pingIdInput:GetPropertyChangedSignal("Text"):Connect(function()
        pingUserId = pingIdInput.Text:gsub("%s+", "")
    end)

    -- Toggle ping checkbox
    local pingBtn = Instance.new("TextButton", pingRow)
    pingBtn.Size = UDim2.new(1, 0, 1, 0)
    pingBtn.BackgroundTransparency = 1
    pingBtn.Text = ""
    pingBtn.MouseButton1Click:Connect(function()
        pingDisconEnabled = not pingDisconEnabled
        pingCheckmark.Visible = pingDisconEnabled
        pingCheckbox.BackgroundColor3 = pingDisconEnabled and Color3.fromRGB(25, 55, 75) or Color3.fromRGB(55, 55, 70)
        pingCheckbox.BorderColor3 = pingDisconEnabled and Color3.fromRGB(100, 220, 255) or Color3.fromRGB(110, 110, 140)
        pingLabel.TextColor3 = pingDisconEnabled and Color3.fromRGB(140, 220, 255) or Color3.fromRGB(170, 170, 190)
        pingIdInput.Visible = pingDisconEnabled
    end)

    -- ===== KICK / DISCONNECT DETECTION =====
    local function sendKickWebhook(reason, isKick)
        if webhookUrl == "" then return end
        local elapsed = tick() - scriptStartTime
        local credits = getCredits()
        local delta   = (credits and creditsAtStart) and (credits - creditsAtStart) or 0
        local pingStr = (pingDisconEnabled and pingUserId ~= "") and ("<@" .. pingUserId .. "> ") or ""

        local eventType = isKick and "🔨 **KICKED**" or "🔌 **DISCONNECTED**"
        local content = pingStr .. eventType
            .. "\n━━━━━━━━━━━━━━━━━━━━"
            .. "\n👤 **Player:** " .. player.Name
            .. "\n📋 **Reason:** " .. tostring(reason or "Unknown")
            .. "\n⏱ **Session uptime:** " .. formatUptime(elapsed)
            .. "\n🔄 **Rounds completed:** " .. tostring(roundsPlayed)
            .. "\n💰 **Credits:** " .. tostring(credits or "?") .. "C"
            .. "\n📈 **Earned:** +" .. tostring(delta) .. "C"

        pcall(function()
            local body = game:GetService("HttpService"):JSONEncode({content = content})
            if request then
                request({Url=webhookUrl, Method="POST", Headers={["Content-Type"]="application/json"}, Body=body})
            else
                game:GetService("HttpService"):PostAsync(webhookUrl, body, Enum.HttpContentType.ApplicationJson)
            end
        end)
    end

    -- Kick detection: lắng nghe khi player bị kick khỏi game
    game:GetService("Players").LocalPlayer.Kicked:Connect(function(reason)
        if webhookUrl == "" then return end
        sendKickWebhook(reason ~= "" and reason or "No reason provided", true)
    end)

    -- Disconnect detection: khi mất kết nối
    game:GetService("RunService").Heartbeat:Connect(function()
        -- handled via Kicked event above for kicks
    end)
    game.Close:Connect(function()
        if webhookUrl ~= "" then
            sendKickWebhook("Client closed / disconnected", false)
        end
    end)

end
-- ==================== ANTI AFK ====================
local function antiAFK()
    task.spawn(function()
        local VirtualUser = game:GetService("VirtualUser")
        player.Idled:Connect(function()
            VirtualUser:CaptureController()
            VirtualUser:ClickButton2(Vector2.new())
        end)
        while true do
            task.wait(600)
            pcall(function()
                VirtualUser:CaptureController()
                VirtualUser:ClickButton2(Vector2.new())
            end)
        end
    end)
end

