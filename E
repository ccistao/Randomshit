        end
        if intervalDrag then
            setInterval(1 + math.clamp((p.X - intervalBg.AbsolutePosition.X) / math.max(1, intervalBg.AbsoluteSize.X), 0, 1) * 59)
        end
        if dragging and dragStart then
            local sw = screenGui.AbsoluteSize
            local d = p - dragStart
            frame.Position = UDim2.fromOffset(
                math.clamp(startPos.X + d.X, 0, sw.X - frame.AbsoluteSize.X),
