-- ==================== LOBBY DETECTION (position-based) ====================
local LOBBY_MIN = Vector3.new(-21, -40, -512)
local LOBBY_MAX = Vector3.new(413, 80, -253)

local function isInLobby()
    local char = player.Character
    if not char then return true end
    local root = char:FindFirstChild("HumanoidRootPart")
    if not root then return true end
    local pos = root.Position
    return pos.X >= LOBBY_MIN.X and pos.X <= LOBBY_MAX.X
       and pos.Y >= LOBBY_MIN.Y and pos.Y <= LOBBY_MAX.Y
       and pos.Z >= LOBBY_MIN.Z and pos.Z <= LOBBY_MAX.Z
end

local function isInGame()
    return not isInLobby()
end

-- ==================== GAME ACTIVE CHECK ====================
local function isGameActive()
    local gs = ReplicatedStorage:FindFirstChild("GameStatus")
    local txt = gs and tostring(gs.Value):upper() or ""
    -- HEAD START = game đang bắt đầu, luôn active dù position đâu
    if txt:find("HEAD START") then return true end
    -- Ngoài HEAD START thì check position
    if isInLobby() then return false end
    -- Explicit game over states
    if txt:find("GAME OVER") or txt:find("BEAST LEFT")
    or txt:find("BEF LAI") or txt:find("KET THUC")
    or txt:find("TRO CHOI KET THUC") then
        return false
    end
    return true
end

-- ==================== WAIT FOR GAME ====================
local function waitForGameActive()
    local curStatus = ReplicatedStorage:FindFirstChild("GameStatus")
    curStatus = curStatus and tostring(curStatus.Value):upper() or ""
    local mapVal = ReplicatedStorage:FindFirstChild("CurrentMap")
    local mapStatus = mapVal and mapVal.Value and mapVal.Value.Name or "nil"
    log("waitForGame: lobby=" .. tostring(isInLobby()) .. " map='" .. mapStatus .. "' status='" .. curStatus .. "'")

    -- Nếu đang trong map nhưng game over -> chờ về sảnh trước
    if isInGame() and (curStatus:find("GAME OVER") or curStatus:find("BEAST LEFT") or curStatus:find("INTERMISSION")) then
        log("waitForGame: game over in map, waiting for lobby...")
        repeat task.wait(0.5) until isInLobby() or not scriptEnabled
    end

    -- Nếu đang trong map và game active -> bắt đầu ngay
    if isInGame() then
        log("waitForGame: already in-game, starting now")
        return true
    end

    -- Đang trong sảnh -> chờ TP vào map
    updateStatus("Waiting for game...")

    -- Chờ cho tới khi bị TP vào map (thoát khỏi lobby box)
    local timeout = 300
    local elapsed = 0
    local lastLoggedSec = -1
    while elapsed < timeout do
        task.wait(0.5)
        elapsed = elapsed + 0.5

        if isInGame() then
            log("waitForGame: TP'd into map! Starting...")
            task.wait(1)
            return true
        end

        local logSec = math.floor(elapsed)
        if logSec % 15 == 0 and elapsed > 0 and logSec ~= lastLoggedSec then
            lastLoggedSec = logSec
            local mapV = ReplicatedStorage:FindFirstChild("CurrentMap")
            local mapN = mapV and mapV.Value and mapV.Value.Name or "nil"
            log("waitForGame: still waiting... map='" .. mapN .. "' (" .. logSec .. "s)")
        end
    end

    log("waitForGame: timeout after " .. timeout .. "s!")
    return false
end

