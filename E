            task.wait(0.2); elapsed += 0.2
            if not scriptEnabled or not canAutoJump or gameOver or not currentTrigger then
                shouldJump = false; break
            end
            if isCoHacking() then
                -- Pin lại trigger, restart timer
                shouldJump = false
                local lr = rootPart
                if lr and lr.Parent and currentTrigger and currentTrigger.Parent then
                    pcall(function()
                        lr.CFrame = currentTrigger.CFrame + Vector3.new(0, 0.5, 0)
                        lr.AssemblyLinearVelocity = Vector3.zero
                    end)
                end
                break
            end
        end
        if not shouldJump then continue end
        if not scriptEnabled or not canAutoJump or gameOver or not currentTrigger then continue end
        if isCoHacking() then continue end
        local localRoot = rootPart
        if not localRoot or not localRoot.Parent then continue end
        pcall(function()
            localRoot.CFrame = CFrame.new(localRoot.CFrame.Position + Vector3.new(0, 7, 0))
        end)
        task.wait(0.07)
        pcall(function()
            if currentTrigger and currentTrigger.Parent then
                localRoot.CFrame = currentTrigger.CFrame + Vector3.new(0, 0.5, 0)
            end
        end)
    end
end)

local function getPCNearPlayer(targetPlayer)
    if not targetPlayer or not targetPlayer.Character then return nil end
    local targetRoot = targetPlayer.Character:FindFirstChild("HumanoidRootPart")
    if not targetRoot then return nil end
    local nearest, nearestDist = nil, math.huge
    for _, pcData in ipairs(allPCs) do
        for _, trigger in ipairs(pcData.triggers) do
            local dist = (targetRoot.Position - trigger.Position).Magnitude
            if dist < nearestDist then nearest = pcData nearestDist = dist end
        end
    end
    return (nearestDist < 15) and nearest or nil
end

