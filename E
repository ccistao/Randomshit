-- ============================================================
-- TWEEN ENGINE
-- ============================================================
local isMoving     = false
local currentPC    = nil
local currentTrigger = nil
local canAutoJump  = false
local isHacking    = false
local isSaving     = false
local isReturning  = false

-- Core tween function - returns true = reached, false = interrupted
local function tweenTo(targetPos, spd, myTok)
    local STOP_DIST = 1.0
    while true do
        task.wait()
        if not scriptEnabled or scriptToken ~= myTok then return false end
        if isSaving then return false end
        if gameOver or not isGameActive() then return false end
        if isFindExitPhase() and not hackExtraPC then return false end
        local root = rootPart
        if not root or not root.Parent then return false end
        local diff = targetPos - root.Position
        if diff.Magnitude <= STOP_DIST then
            root.CFrame = CFrame.new(targetPos)
            root.AssemblyLinearVelocity = Vector3.zero
            root.AssemblyAngularVelocity = Vector3.zero
            return true
        end
        root.AssemblyLinearVelocity = diff.Unit * spd
        root.AssemblyAngularVelocity = Vector3.zero
    end
end

-- Noclip Heartbeat connection - returns disconnect function
local function startNoclip()
    local active = true
    local conn = RunService.Heartbeat:Connect(function()
        if not active or not scriptEnabled then return end
        local c = player.Character
        if not c then return end
        for _, p in pairs(c:GetChildren()) do
            if p:IsA("BasePart") then p.CanCollide = false end
            if p:IsA("Model") then
                for _, pp in pairs(p:GetChildren()) do
                    if pp:IsA("BasePart") then pp.CanCollide = false end
                end
            end
        end
    end)
    return function()
        active = false
        conn:Disconnect()
    end
end

-- Move tới trigger: U-shape (xuống → ngang → lên) để tránh detection
local function moveTo(trigger, myTok, isFirst)
    if not rootPart then return end
    local char = player.Character
    if not char then return end
    local hum = char:FindFirstChild("Humanoid")

    -- First move of round hoặc returning after save: TP thẳng
    if isFirst or isReturning then
        local wasReturning = isReturning
        isReturning = false
        log("[MOVE] TP thẳng" .. (wasReturning and " (sau save)" or " (đầu ván)"))
        rootPart.CFrame = trigger.CFrame + Vector3.new(0, 0.5, 0)
        task.wait(0.1)
        return
    end

    while isMoving do task.wait(0.1) end
    isMoving = true
    if hum then hum.PlatformStand = true hum:ChangeState(Enum.HumanoidStateType.Physics) end

    local stopNoclip = startNoclip()
    local savedG = workspace.Gravity
    workspace.Gravity = 0

    local myY  = rootPart.Position.Y
    local tgtY = trigger.Position.Y + 0.5
    local downY = math.min(myY - 50, tgtY - 10)
    local spd   = tweenSpeed

    local ok1 = tweenTo(Vector3.new(rootPart.Position.X, downY, rootPart.Position.Z), spd * 1.1, myTok)
    if ok1 then
        local ok2 = tweenTo(Vector3.new(trigger.Position.X, downY, trigger.Position.Z), spd * 1.1, myTok)
        if ok2 then tweenTo(Vector3.new(trigger.Position.X, tgtY, trigger.Position.Z), spd, myTok) end
    end

    stopNoclip()
    workspace.Gravity = savedG
    if hum then hum.PlatformStand = false hum:ChangeState(Enum.HumanoidStateType.GettingUp) end
    isMoving = false
end

-- Move thẳng tới trigger (khi thử trigger khác trong cùng PC)
local function moveStraightTo(trigger, myTok)
    if not rootPart then return end
    local char = player.Character
    if not char then return end
    local hum = char:FindFirstChild("Humanoid")

    while isMoving do task.wait(0.1) end
    isMoving = true
    if hum then hum.PlatformStand = true hum:ChangeState(Enum.HumanoidStateType.Physics) end

    local stopNoclip = startNoclip()
    local savedG = workspace.Gravity
    workspace.Gravity = 0
    tweenTo(Vector3.new(trigger.Position.X, trigger.Position.Y + 0.5, trigger.Position.Z), tweenSpeed, myTok)
    stopNoclip()
    workspace.Gravity = savedG
    if hum then hum.PlatformStand = false hum:ChangeState(Enum.HumanoidStateType.GettingUp) end
    isMoving = false
end

-- ============================================================
-- HACK PC
-- ============================================================
local gameOver = false

local function hackPC(pcData, myTok, isFirstMove)
    if not pcData or not scriptEnabled or scriptToken ~= myTok then return false end
    if gameOver or not isGameActive() then return false end
    if isFindExitPhase() and not hackExtraPC then return false end

    local pcId   = tostring(pcData.id)
    local pcName = pcData.computer.Name or "?"

    -- Skip nếu screen xanh (done rồi)
    if isScreenGreen(pcData) then
        log("✅ [PC" .. pcId .. "] Screen đã xanh → skip")
        hackedPCs[pcData.id] = true
        return true
    end
    if getPCProgress(pcData) >= 1 then
        log("✅ [PC" .. pcId .. "] Progress done → skip")
        hackedPCs[pcData.id] = true
        return true
    end
    if isFindExitPhase() and not hackExtraPC then return false end

    log("[PC" .. pcId .. "] Bắt đầu hack | triggers=" .. #pcData.triggers)

    local chosenTrigger = nil
    local isFirst = isFirstMove or false

    -- Thử từng trigger
    for i, trigger in ipairs(pcData.triggers) do
        if not scriptEnabled or scriptToken ~= myTok then return false end
        if isSaving or isReturning then return false end
        if isFindExitPhase() and not hackExtraPC then return false end

        if i == 1 then
            moveTo(trigger, myTok, isFirst)
        else
            moveStraightTo(trigger, myTok)
        end

        -- Check lại screen sau khi tween tới
        if isScreenGreen(pcData) then
            log("✅ [PC" .. pcId .. "] Screen xanh sau tween → skip")
            hackedPCs[pcData.id] = true
            isMoving = false; canAutoJump = false
            return true
        end

        currentTrigger = trigger
        canAutoJump    = true

        local progressBefore = getPlayerActionProgress()
        pcall(function()
            if trigger and rootPart then
                safeFire(rootPart, trigger, 0)
                task.wait(0.1)
                safeFire(rootPart, trigger, 1)
            end
        end)

        -- Spam fire 1s để kiểm tra trigger work, với beast check
        local spamTime = 0
        while spamTime < 1 do
            task.wait(0.1); spamTime += 0.1
            if not scriptEnabled or scriptToken ~= myTok then return false end
            if isSaving or isReturning then return false end
            if beastNearby and not isReturning then break end
            if isFindExitPhase() and not hackExtraPC then return false end
            pcall(function()
                local r = ReplicatedStorage:FindFirstChild("RemoteEvent")
                if r then r:FireServer("Input", "Action", true) end
            end)
        end

        local progressAfter = getPlayerActionProgress()
        if progressAfter > progressBefore + 0.001 then
            chosenTrigger = trigger
            log("PC" .. pcId .. ": trigger " .. i .. " work → " .. math.floor(progressAfter*100) .. "%")
            break
        else
            log("⚡ PC" .. pcId .. ": trigger " .. i .. " no response, next...")
            canAutoJump = false
            currentTrigger = nil
        end
    end

    if not chosenTrigger then
        log("❌ PC" .. pcId .. ": ALL triggers fail → skip")
        isMoving = false; canAutoJump = false; currentTrigger = nil
        return false
    end

    -- === HACK LOOP ===
    setState("hacking")
    isHacking  = true
    currentPC  = pcData
    updateStatus("Hacking PC " .. pcId)

    -- Freeze character khi hack: BodyPosition + BodyGyro (chống joystick di chuyển)
    local hackChar = player.Character
    local hackHum  = hackChar and hackChar:FindFirstChild("Humanoid")
    local hackRoot = hackChar and hackChar:FindFirstChild("HumanoidRootPart")

    local _bpos, _bgyr
    if hackRoot and hackRoot.Parent then
        pcall(function()
            _bpos = Instance.new("BodyPosition")
            _bpos.Name     = "HackFreeze_Pos"
            _bpos.Position = hackRoot.Position
            _bpos.MaxForce = Vector3.new(1e6, 1e6, 1e6)
            _bpos.D        = 1000
            _bpos.P        = 50000
            _bpos.Parent   = hackRoot

            _bgyr = Instance.new("BodyGyro")
            _bgyr.Name      = "HackFreeze_Gyro"
            _bgyr.CFrame    = hackRoot.CFrame
            _bgyr.MaxTorque = Vector3.new(1e6, 1e6, 1e6)
            _bgyr.D         = 1000
            _bgyr.P         = 50000
            _bgyr.Parent    = hackRoot
        end)
    end

    local function unfreezeHack()
        pcall(function() if _bpos and _bpos.Parent then _bpos:Destroy() end end)
        pcall(function() if _bgyr and _bgyr.Parent then _bgyr:Destroy() end end)
        -- Cleanup nếu còn sót trong character hiện tại
        pcall(function()
            local cur = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
            if cur then
                local p = cur:FindFirstChild("HackFreeze_Pos")
                local g = cur:FindFirstChild("HackFreeze_Gyro")
                if p then p:Destroy() end
                if g then g:Destroy() end
            end
        end)
    end

    local hackTok = myTok
    while isHacking and scriptEnabled and scriptToken == hackTok and not gameOver do
        task.wait(0.1)
        if not isGameActive() then
            log("Game ended mid-hack")
            isHacking = false; break
        end
        if isFindExitPhase() and not hackExtraPC then
            log("🚪 [PC" .. pcId .. "] Find Exit → dừng hack")
            isHacking = false; unfreezeHack()
            currentPC = nil; canAutoJump = false; currentTrigger = nil
            setState("exiting")
            return false
        end
        if beastNearby and not isReturning and not isSaving then
            local _bd = 0
            pcall(function()
                local _br = beast and beast.Character and (beast.Character:FindFirstChild("HumanoidRootPart") or beast.Character:FindFirstChild("Torso"))
                if _br and rootPart then _bd = math.floor((rootPart.Position - _br.Position).Magnitude) end
            end)
            log("⚠ [PC" .. pcId .. "] Beast cách " .. _bd .. " studs → skip")
            isHacking = false; isMoving = false
            skippedPCs[pcData.id] = true
            unfreezeHack()
            currentPC = nil; canAutoJump = false; currentTrigger = nil
            setState("moving")
            return false
        end
        if isSaving or isReturning then
            unfreezeHack()
            isHacking = false; currentPC = nil; canAutoJump = false; currentTrigger = nil
            return false
        end
        if playerMode == "alt" and isSelfCaged() then
            log("PC" .. pcId .. ": ALT caged → stop hack")
            isHacking = false; unfreezeHack()
            currentPC = nil; canAutoJump = false; currentTrigger = nil
            return false
        end
        if not pcData.computer or not pcData.computer.Parent then
            log("❌ PC" .. pcId .. ": disappeared!")
            unfreezeHack(); break
        end

        -- Fire action
        pcall(function()
            local r = ReplicatedStorage:FindFirstChild("RemoteEvent")
            if r then r:FireServer("Input", "Action", true) end
        end)
        -- Skill check
        if pcData.computer:FindFirstChild("SkillCheckActive")
        and pcData.computer.SkillCheckActive.Value then
            pcall(function()
                local r = ReplicatedStorage:FindFirstChild("RemoteEvent")
                if r then r:FireServer("SkillCheck", true) end
            end)
        end

        -- Done check
        if isScreenGreen(pcData) or getPCProgress(pcData) >= 0.999 then
            log("✅ [PC" .. pcId .. "] Hack xong!")
            updateStatus("Done PC " .. pcId)
            hackedPCs[pcData.id] = true
            canAutoJump = false; currentTrigger = nil
            isHacking = false; currentPC = nil
            allPCs = findAllPCs()
            unfreezeHack()
            -- Check exit ngay sau khi done PC, không cần chờ tween sang PC khác
            if isFindExitPhase() and not hackExtraPC then
                setState("exiting")
                return true
            end
            setState("moving")
            return true
        end
    end

    unfreezeHack()
    isHacking = false; currentPC = nil; canAutoJump = false; currentTrigger = nil
    if STATE == "hacking" then setState("moving") end
    return false
end

