local CONFIG_FILE = "ftf_config.json"

-- Runtime config (đọc/ghi bởi GUI + saveConfig)
local tweenSpeed        = 30
local hackExtraPC       = false
local altCageDelay      = 60
local playerMode        = "main"  -- "main" | "alt"
