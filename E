local function getHammerEvent()
    local c = player.Character
    local h = c and c:FindFirstChild("Hammer")
    return h and h:FindFirstChild("HammerEvent")
end

local function getBeastNearestSurvivor(excludeName)
    local c = player.Character; if not c then return nil end
    local root = c:FindFirstChild("HumanoidRootPart"); if not root then return nil end
    local nearest, nd = nil, math.huge
    local map = ReplicatedStorage:FindFirstChild("CurrentMap")
    map = map and map.Value
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= player and p.Character then
            if excludeName and p.Name == excludeName then continue end
            local hum   = p.Character:FindFirstChild("Humanoid")
            local torso = p.Character:FindFirstChild("UpperTorso") or p.Character:FindFirstChild("Torso")
            if hum and torso and not hum.PlatformStand and hum.Health > 0 then
                local captured = false
                if map then
                    for _, v in ipairs(map:GetChildren()) do
                        if v.Name == "FreezePod" then
                            local ct = v:FindFirstChild("CapturedTorso", true)
                            if ct and ct.Value == torso then captured = true break end
                        end
                    end
                end
                if not captured then
                    local d = (root.Position - torso.Position).Magnitude
                    if d < nd then nearest = p; nd = d end
                end
            end
        end
    end
    return nearest
end

local function getBeastNearestRagdoll()
    local c = player.Character; if not c then return nil end
    local root = c:FindFirstChild("HumanoidRootPart"); if not root then return nil end
    local nearest, nd = nil, math.huge
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= player and p.Character then
            local hum   = p.Character:FindFirstChild("Humanoid")
            local torso = p.Character:FindFirstChild("UpperTorso") or p.Character:FindFirstChild("Torso")
            if hum and torso and hum.PlatformStand then
                local d = (root.Position - torso.Position).Magnitude
                if d < nd then nearest = p; nd = d end
            end
        end
    end
    return nearest
end

local function getBeastNearestEmptyCage()
    local c = player.Character; if not c then return nil end
    local root = c:FindFirstChild("HumanoidRootPart"); if not root then return nil end
    local map = ReplicatedStorage:FindFirstChild("CurrentMap")
    map = map and map.Value; if not map then return nil end
    local nearest, nd = nil, math.huge
    for _, v in ipairs(map:GetChildren()) do
        if v.Name == "FreezePod" then
            local ct = v:FindFirstChild("CapturedTorso", true)
            if ct and ct.Value == nil then
                local trig = v:FindFirstChild("PodTrigger", true)
                if trig then
                    local d = (root.Position - trig.Position).Magnitude
                    if d < nd then nearest = v; nd = d end
                end
            end
        end
    end
    return nearest
end

local function beastLoop()
    while true do
        task.wait(0.05)
        if not scriptEnabled or not isSelfBeast() then continue end
        if not isGameActive() then
            updateStatus("Beast: waiting for round...")
            repeat task.wait(0.5) until isGameActive() or not scriptEnabled
            continue
        end

        local remote = getHammerEvent()
        if not remote then continue end
        local c    = player.Character; if not c then continue end
        local root = c:FindFirstChild("HumanoidRootPart"); if not root then continue end

        -- Priority 1: Có rope → cage ngay
        local ropeCheck = c:FindFirstChild("RopeConstraint", true)
        if ropeCheck then
            local cage = getBeastNearestEmptyCage()
            if cage then
                local trig = cage:FindFirstChild("PodTrigger", true)
                if trig then
                    updateStatus("Beast: Caging...")
                    local cageCenter = cage:GetModelCFrame().Position
                    local dir = (cageCenter - trig.Position)
                    if dir.Magnitude > 0 then dir = dir.Unit * 2 else dir = Vector3.zero end
                    local pos = Vector3.new(trig.Position.X + dir.X, trig.Position.Y, trig.Position.Z + dir.Z)
                    local hum = c:FindFirstChild("Humanoid")
                    if hum then hum.PlatformStand = true hum:ChangeState(Enum.HumanoidStateType.Physics) end

                    local ncParts3 = {}
                    pcall(function()
                        for _, p in pairs(player.Character:GetDescendants()) do
                            if p:IsA("BasePart") then table.insert(ncParts3, p) end
                        end
                    end)
                    local ncActive3 = true
                    local ncConn3 = RunService.Stepped:Connect(function()
                        if not ncActive3 then return end
                        for _, p in ipairs(ncParts3) do if p and p.Parent then p.CanCollide = false end end
                    end)
                    local fzActive3 = true
                    local fzConn3 = RunService.Heartbeat:Connect(function()
                        if not fzActive3 or not scriptEnabled then return end
                        root.CFrame = CFrame.new(pos)
                        root.AssemblyLinearVelocity = Vector3.zero
                        root.AssemblyAngularVelocity = Vector3.zero
                    end)
                    root.CFrame = CFrame.new(pos)
                    root.AssemblyLinearVelocity = Vector3.zero

                    local t3 = 0
                    while t3 < 2.5 do
                        pcall(function()
                            safeFire(root, trig, 0); safeFire(root, trig, 1)
                            local re = ReplicatedStorage:FindFirstChild("RemoteEvent")
                            if re then re:FireServer("Input", "Action", true) end
                        end)
                        local ct3 = cage:FindFirstChild("CapturedTorso", true)
                        if ct3 and ct3.Value ~= nil then break end
                        task.wait(0.05); t3 += 0.05
                    end

                    fzActive3 = false; fzConn3:Disconnect()
                    ncActive3 = false; ncConn3:Disconnect()
                    if hum then hum.PlatformStand = false hum:ChangeState(Enum.HumanoidStateType.GettingUp) end
                end
            end
            continue
        end

        -- Priority 2: Có ragdoll → rope ngay
        local ragdollTarget = getBeastNearestRagdoll()
        if ragdollTarget and ragdollTarget.Character then
            local torso = ragdollTarget.Character:FindFirstChild("UpperTorso") or ragdollTarget.Character:FindFirstChild("Torso")
            if torso then
                updateStatus("Beast: Roping " .. ragdollTarget.Name)
                root.CFrame = CFrame.new(torso.Position + Vector3.new(0, 0, 1))
                local rt = 0
                while rt < 1.5 do
                    remote:FireServer("HammerTieUp", torso, torso.Position)
                    if c:FindFirstChild("RopeConstraint", true) then break end
                    task.wait(0.05); rt += 0.05
                end
                continue
            end
        end

        -- Priority 3: Hit survivor
        local target
        if playerMode == "alt" then
            local elapsed = tick() - altRoundStartTick
            if elapsed < altCageDelay then
                updateStatus("Beast ALT: Wait " .. math.ceil(altCageDelay - elapsed) .. "s...")
                task.wait(0.5); continue
            end
            local mainEscaped = false
            pcall(function()
                local main = Players:FindFirstChild(followTargetName)
                if main then
                    local st = main:FindFirstChild("TempPlayerStatsModule")
                    local f  = st and st:FindFirstChild("Escaped")
                    mainEscaped = f and f.Value == true
                end
            end)
            target = mainEscaped and getBeastNearestSurvivor() or getBeastNearestSurvivor(followTargetName)
        else
            target = getBeastNearestSurvivor()
        end

        if not target or not target.Character then
            updateStatus("Beast: All captured!")
            log("👹 Tất cả đã cage → chờ ván sau")
            repeat task.wait(0.5) until not isGameActive() or not scriptEnabled or not isSelfBeast()
            continue
        end

        local torso = target.Character:FindFirstChild("UpperTorso") or target.Character:FindFirstChild("Torso")
        if not torso then continue end
        local hum = target.Character:FindFirstChild("Humanoid")
        if hum and hum.PlatformStand then continue end

        updateStatus("Beast: Hitting " .. target.Name)
        root.CFrame = CFrame.new(torso.Position + Vector3.new(0, 0, 0.5))

        local hitTimer   = 0
        local ragdollTimer = 0
        while hitTimer < 1.5 do
            if not target.Character then break end
            local h2 = target.Character:FindFirstChild("Humanoid")
            if h2 and (h2.PlatformStand or h2.Health <= 0) then
                log("👹 " .. target.Name .. " caged!"); break
            end
            -- Check FreezePod
            local targetCaged = false
            pcall(function()
