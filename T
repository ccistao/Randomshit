local shooter = workspace["Pea Shooter"]
local ballTemplate = game.ReplicatedStorage.Ball

while true do
    task.wait(3)

    local ball = ballTemplate:Clone()
    ball.Parent = workspace
    ball.Anchored = false
    ball.CanCollide = false
    ball.CFrame = shooter:GetPivot() * CFrame.new(0, 0, -2)

    local bv = Instance.new("BodyVelocity")
    bv.Velocity = shooter:GetPivot().LookVector * 30
    bv.MaxForce = Vector3.new(math.huge, math.huge, math.huge)
    bv.Parent = ball

    task.delay(4, function()
        ball:Destroy()
    end)
end
