local ReplicatedStorage = game:GetService("ReplicatedStorage")
local Players = game:GetService("Players")
local PhysicsService = game:GetService("PhysicsService") -- Gọi thêm dịch vụ vật lý

-- ==========================================
-- CÀI ĐẶT ĐỂ ZOMBIE ĐI XUYÊN QUA NHAU
-- ==========================================
-- Đăng ký một nhóm va chạm tên là "HoiZombie"
PhysicsService:RegisterCollisionGroup("HoiZombie")
-- Lệnh cho những đứa trong "HoiZombie" KHÔNG ĐƯỢC đụng nhau
PhysicsService:CollisionGroupSetCollidable("HoiZombie", "HoiZombie", false)

local Spawns = workspace:WaitForChild("Spawns")
local Ends = workspace:WaitForChild("Ends")
local ZombieTemplate = ReplicatedStorage:WaitForChild("Zombie")

-- ==========================================
-- HỆ THỐNG ZOMBIE DI CHUYỂN
-- ==========================================
local function spawnZombie()
	local randomLane = tostring(math.random(1, 5))
	local spawnPart = Spawns:FindFirstChild(randomLane)
	local endPart = Ends:FindFirstChild(randomLane)
	
	if spawnPart and endPart then
		local newZombie = ZombieTemplate:Clone()
		
		-- Ép toàn bộ cơ thể con Zombie mới này vào nhóm "HoiZombie"
		for _, part in pairs(newZombie:GetDescendants()) do
			if part:IsA("BasePart") then
				part.CollisionGroup = "HoiZombie"
			end
		end
		
		newZombie.Parent = workspace
		newZombie:SetPrimaryPartCFrame(spawnPart.CFrame + Vector3.new(0, 3, 0))
		
		local humanoid = newZombie:FindFirstChild("Humanoid")
		if humanoid then
			humanoid:MoveTo(endPart.Position)
			
			-- Bổ sung: Lỡ nó đi tới nơi mà lag chưa chạm đích thì bắt nó đi tiếp
			humanoid.MoveToFinished:Connect(function()
				humanoid:MoveTo(endPart.Position)
			end)
		end
	end
end

-- Vòng lặp đẻ quái (Tạm để 2 giây 1 con cho ông dễ test)
task.spawn(function()
	while task.wait(2) do
		spawnZombie()
	end
end)

-- ==========================================
-- HỆ THỐNG ZOMBIE VÀO NHÀ -> GAME OVER
-- ==========================================
for _, endPart in pairs(Ends:GetChildren()) do
	endPart.Touched:Connect(function(hit)
		local character = hit.Parent
		if character and character.Name == "Zombie" then
			character:Destroy()
			print("TOANG! ZOMBIE ĐÃ VÀO NHÀ!")
			for _, player in pairs(Players:GetPlayers()) do
				local playerChar = player.Character
				if playerChar and playerChar:FindFirstChild("Humanoid") then
					playerChar.Humanoid.Health = 0
				end
			end
		end
	end)
end
