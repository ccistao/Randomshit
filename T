local shooter = workspace.Model.Model
local ballTemplate = game.ReplicatedStorage.Ball
local head = shooter.PrimaryPart

while true do
    task.wait(3)

    local ball = ballTemplate:Clone()
    ball.Parent = workspace
    ball.Anchored = false
    ball.CFrame = head.CFrame * CFrame.new(0, 0, -2)
    ball.AssemblyLinearVelocity = head.CFrame.LookVector * 30

    task.delay(4, function()
        ball:Destroy()
    end)
end
